{
	# Global options
	admin off
	persist_config off
	auto_https off
}

:80 {
	root * /usr/share/caddy
	encode zstd gzip
	file_server

	# Cache immutable assets (fingerprinted by Astro)
	@assets path /_astro/* /funders/* /showcase/* /niamoto_logo.png
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# HTML pages — revalidate quickly
	@html path *.html /
	header @html Cache-Control "public, max-age=0, must-revalidate"

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
	}

	# Pretty URLs — try adding /index.html for directory paths
	try_files {path} {path}/index.html {path}.html

	# 404 fallback (Astro generates 404.html at build time)
	handle_errors {
		@404 expression {err.status_code} == 404
		rewrite @404 /404.html
		file_server
	}
}
