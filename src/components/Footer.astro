---
import NiamotoLogo from "./NiamotoLogo.astro";

const columns = [
  {
    title: "Project",
    links: [
      { label: "Documentation", href: "/documentation" },
      { label: "Plugins", href: "/plugins" },
      { label: "Showcase", href: "/showcase/nouvelle-caledonie" },
      { label: "Changelog", href: "https://github.com/niamoto/niamoto/releases" },
    ],
  },
  {
    title: "Community",
    links: [
      { label: "GitHub", href: "https://github.com/niamoto/niamoto" },
      {
        label: "Discussions",
        href: "https://github.com/niamoto/niamoto/discussions",
      },
      {
        label: "Contributing",
        href: "https://github.com/niamoto/niamoto/blob/main/CONTRIBUTING.md",
      },
      {
        label: "Code of Conduct",
        href: "https://github.com/niamoto/niamoto/blob/main/CODE_OF_CONDUCT.md",
      },
    ],
  },
  {
    title: "Made by",
    links: [
      { label: "Arsis · Independent dev studio", href: "https://arsis.dev" },
      { label: "Montpellier, France", href: null },
    ],
  },
];
---

<footer class="mt-32 bg-[#1E1E22] text-white">
  <div class="mx-auto max-w-[1200px] px-6 py-16">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-4">
      <div class="md:col-span-1">
        <NiamotoLogo size="md" color="light" />
        <p class="mt-3 max-w-xs text-sm text-stone-light">
          Ecological data, from field to web.
        </p>
        <p class="mt-4 font-mono text-xs text-stone-light opacity-70">
          GPL v3
        </p>
      </div>

      {
        columns.map((col) => (
          <div>
            <h4 class="mb-4 text-sm font-semibold tracking-wide text-white">
              {col.title}
            </h4>
            <ul class="space-y-3">
              {col.links.map((link) => (
                <li>
                  {link.href ? (
                    <a
                      href={link.href}
                      class="text-sm text-stone-light transition-colors hover:text-white"
                    >
                      {link.label}
                    </a>
                  ) : (
                    <span class="text-sm text-stone-light">{link.label}</span>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-16 border-t border-white/10 pt-6 text-center text-xs text-stone-light"
    >
      <span>© 2026 Niamoto contributors</span>
    </div>
  </div>
</footer>
