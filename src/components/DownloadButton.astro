---
// OS-detecting download button.
// Renders a default "Download" label server-side (for SSG / no-JS safety),
// then client-side script swaps the label + href to match the user's OS.
//
// Release URLs point to the GitHub Releases page with platform-specific
// asset filters. Update once v1 is published.

export interface Props {
  size?: "sm" | "md" | "lg";
  showAlternatives?: boolean;
  variant?: "primary" | "outline";
}

const {
  size = "md",
  showAlternatives = true,
  variant = "primary",
} = Astro.props;

const sizeClass = {
  sm: "px-4 py-2 text-sm gap-2",
  md: "px-6 py-3 text-[15px] gap-2",
  lg: "px-8 py-4 text-base gap-3",
}[size];

const variantClass = {
  primary:
    "bg-forest-green text-white shadow-[0_10px_24px_rgba(46,125,50,0.18)] hover:bg-forest-green-dark",
  outline:
    "bg-white text-ink border border-border-strong hover:bg-surface-low",
}[variant];

// Release page — GitHub will redirect to the latest version
const releaseBase = "https://github.com/niamoto/niamoto/releases/latest";
---

<div class="inline-flex flex-col items-center gap-3">
  <a
    href={releaseBase}
    class={`download-btn inline-flex items-center justify-center rounded-[8px] font-semibold transition-colors duration-150 no-underline ${variantClass} ${sizeClass}`}
    data-os-default={releaseBase}
    data-os-macos={`${releaseBase}`}
    data-os-linux={`${releaseBase}`}
    data-os-windows={`${releaseBase}`}
  >
    {/* SVG icon changes per OS via client script */}
    <svg
      class="download-btn__icon"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
      <polyline points="7 10 12 15 17 10" />
      <line x1="12" y1="15" x2="12" y2="3" />
    </svg>
    <span class="download-btn__label">Download Niamoto</span>
  </a>

  {
    showAlternatives && (
      <div class="flex items-center gap-4 text-xs text-stone">
        <span class="download-alt" data-os="macos">
          <a href={releaseBase} class="hover:text-ink hover:underline">
            macOS
          </a>
        </span>
        <span class="text-stone-light" aria-hidden="true">·</span>
        <span class="download-alt" data-os="linux">
          <a href={releaseBase} class="hover:text-ink hover:underline">
            Linux
          </a>
        </span>
        <span class="text-stone-light" aria-hidden="true">·</span>
        <span class="download-alt" data-os="windows">
          <a href={releaseBase} class="hover:text-ink hover:underline">
            Windows
          </a>
        </span>
      </div>
    )
  }
</div>

<script>
  type OS = "macos" | "linux" | "windows" | "other";

  function detectOS(): OS {
    const ua = navigator.userAgent.toLowerCase();
    if (ua.includes("mac")) return "macos";
    if (ua.includes("win")) return "windows";
    if (ua.includes("linux") || ua.includes("x11")) return "linux";
    return "other";
  }

  const osLabels: Record<Exclude<OS, "other">, string> = {
    macos: "Download for macOS",
    linux: "Download for Linux",
    windows: "Download for Windows",
  };

  const os = detectOS();

  document
    .querySelectorAll<HTMLAnchorElement>(".download-btn")
    .forEach((btn) => {
      if (os !== "other") {
        const label = btn.querySelector<HTMLSpanElement>(".download-btn__label");
        if (label) label.textContent = osLabels[os];
        const targetHref = btn.dataset[`os${os.charAt(0).toUpperCase() + os.slice(1)}`];
        if (targetHref) btn.setAttribute("href", targetHref);
      }
    });

  // Highlight current OS in the "alternatives" row
  document
    .querySelectorAll<HTMLSpanElement>(".download-alt")
    .forEach((span) => {
      if (span.dataset.os === os) {
        span.classList.add("font-semibold", "text-ink");
      }
    });
</script>
