---
// Wordmark + leaf glyph
export interface Props {
  size?: "sm" | "md" | "lg";
  color?: "dark" | "light";
}

const { size = "md", color = "dark" } = Astro.props;

const sizes = {
  sm: { glyph: 20, text: 16 },
  md: { glyph: 24, text: 20 },
  lg: { glyph: 48, text: 40 },
};

const { glyph, text } = sizes[size];
const textColor = color === "dark" ? "text-ink" : "text-white";
---

<a href="/" class={`inline-flex items-center gap-2 ${textColor}`}>
  <img
    src="/niamoto_logo.png"
    alt=""
    aria-hidden="true"
    width={glyph}
    height={glyph}
    class="shrink-0"
    style={`width: ${glyph}px; height: ${glyph}px;`}
  />
  <span
    style={`font-size: ${text}px; font-weight: 700; letter-spacing: -0.02em;`}
    >Niamoto</span
  >
</a>
