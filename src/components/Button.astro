---
export interface Props {
  variant?: "primary" | "outline" | "ghost";
  href?: string;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { variant = "primary", href, size = "md", class: className = "" } = Astro.props;

const variantClass = {
  primary:
    "bg-forest-green text-white shadow-[0_10px_24px_rgba(46,125,50,0.18)] hover:bg-forest-green-dark",
  outline:
    "bg-white text-ink border border-border-strong hover:bg-surface-low",
  ghost: "bg-transparent text-ink hover:bg-surface-low",
}[variant];

const sizeClass = {
  sm: "px-4 py-2 text-sm",
  md: "px-6 py-3 text-[15px]",
  lg: "px-8 py-4 text-base",
}[size];

const base =
  "inline-flex items-center justify-center gap-2 rounded-[8px] font-semibold transition-colors duration-150 no-underline";
const Tag = href ? "a" : "button";
---

<Tag href={href} class={`${base} ${variantClass} ${sizeClass} ${className}`}>
  <slot />
</Tag>
