---
/*
 * FunderGrid — partner logo strip reworked for /alt/.
 * 9 logos at 50% opacity, lifted to 100% on hover.
 * Mirrors the order from public/funders/manifest.yaml.
 */

interface Props {
  /** Optional title/heading shown above the grid. */
  heading?: string;
  /** Optional subtitle rendered beneath the heading (narrative variant only). */
  subtitle?: string;
  /** Variant of presentation. */
  variant?: "default" | "compact" | "narrative";
  class?: string;
}

const {
  heading,
  subtitle,
  variant = "default",
  class: extraClass = "",
} = Astro.props;

interface Funder {
  name: string;
  src: string;
  url: string;
}

// Default ordering (institutions first, research labs, then data providers).
const funders: Funder[] = [
  { name: "Province Nord",                   src: "/funders/pn_100.png",        url: "https://www.province-nord.nc" },
  { name: "Province Sud",                    src: "/funders/ps_100.png",        url: "https://www.province-sud.nc" },
  { name: "OFB",                             src: "/funders/ofb_100.png",       url: "https://www.ofb.gouv.fr" },
  { name: "IRD",                             src: "/funders/ird_100.png",       url: "https://nouvelle-caledonie.ird.fr" },
  { name: "CIRAD",                           src: "/funders/cirad_100.png",     url: "https://www.cirad.fr" },
  { name: "UMR AMAP",                        src: "/funders/amap_100.png",      url: "https://amap.cirad.fr" },
  { name: "IAC",                             src: "/funders/iac_100.png",       url: "https://iac.nc" },
  { name: "Endemia",                         src: "/funders/endemia_100.png",   url: "https://endemia.nc" },
  { name: "Herbier de Nouvelle-Calédonie",   src: "/funders/herbarium_100.png", url: "http://publish.plantnet-project.org/project/herbier-noumea" },
];
---

<section class:list={["alt-funder-grid", `alt-funder-grid--${variant}`, extraClass]}>
  {heading && (
    variant === "narrative"
      ? <h2 class="alt-funder-grid__narrative-heading">{heading}</h2>
      : <h3 class="alt-funder-grid__heading">{heading}</h3>
  )}
  {subtitle && variant === "narrative" && (
    <p class="alt-funder-grid__narrative-sub">{subtitle}</p>
  )}
  <ul class="alt-funder-grid__list">
    {funders.map((f) => (
      <li>
        <a
          href={f.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={f.name}
          class="alt-funder-grid__link"
          title={f.name}
        >
          <img src={f.src} alt={f.name} loading="lazy" decoding="async" />
          {variant === "narrative" && (
            <span class="alt-funder-grid__name">{f.name}</span>
          )}
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .alt-funder-grid {
    width: 100%;
  }
  .alt-funder-grid__heading {
    font-family: var(--f-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--c-muted);
    margin-bottom: 1.25rem;
  }
  .alt-funder-grid__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(9, minmax(0, 1fr));
    gap: 1.5rem;
    align-items: center;
  }
  .alt-funder-grid__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    transition: opacity 240ms cubic-bezier(0.32, 0.72, 0, 1),
                transform 240ms cubic-bezier(0.32, 0.72, 0, 1);
    opacity: 0.5;
  }
  .alt-funder-grid__link:hover,
  .alt-funder-grid__link:focus-visible {
    opacity: 1;
    transform: translateY(-2px);
  }
  .alt-funder-grid__link img {
    max-height: 100%;
    width: auto;
    object-fit: contain;
  }

  /* Dark variants invert logo brightness on hover for legibility. */
  [data-theme="methode"] .alt-funder-grid__link img,
  [data-theme="herbarium"] .alt-funder-grid__link img {
    filter: grayscale(1) brightness(2) contrast(1.1);
  }

  .alt-funder-grid--compact .alt-funder-grid__list {
    gap: 1rem;
  }
  .alt-funder-grid--compact .alt-funder-grid__link {
    height: 32px;
  }

  @media (max-width: 900px) {
    .alt-funder-grid__list {
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 1rem 1.25rem;
    }
  }
  @media (max-width: 480px) {
    .alt-funder-grid__list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  /* ---------- narrative variant ("Our partners" section) ---------- */
  .alt-funder-grid--narrative {
    text-align: center;
  }
  .alt-funder-grid__narrative-heading {
    font-family: var(--f-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--c-ink);
    margin: 0 0 0.25rem;
    letter-spacing: -0.01em;
  }
  .alt-funder-grid__narrative-sub {
    font-size: 0.9rem;
    color: var(--c-muted);
    margin: 0 auto 2.5rem;
    max-width: 40ch;
  }
  .alt-funder-grid--narrative .alt-funder-grid__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-end;
    gap: 2rem 2.5rem;
    grid-template-columns: none;
  }
  .alt-funder-grid--narrative .alt-funder-grid__list > li {
    flex: 0 0 auto;
  }
  .alt-funder-grid--narrative .alt-funder-grid__link {
    height: auto;
    flex-direction: column;
    gap: 0.5rem;
    opacity: 0.75;
    min-width: 100px;
  }
  .alt-funder-grid--narrative .alt-funder-grid__link img {
    height: 48px;
    max-height: 48px;
    max-width: 120px;
    filter: grayscale(1);
    transition: filter 240ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .alt-funder-grid--narrative .alt-funder-grid__link:hover img,
  .alt-funder-grid--narrative .alt-funder-grid__link:focus-visible img {
    filter: grayscale(0);
  }
  .alt-funder-grid--narrative .alt-funder-grid__link:hover,
  .alt-funder-grid--narrative .alt-funder-grid__link:focus-visible {
    opacity: 1;
  }
  .alt-funder-grid__name {
    font-family: var(--f-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-muted);
    text-align: center;
    line-height: 1.2;
  }
  @media (max-width: 640px) {
    .alt-funder-grid--narrative .alt-funder-grid__list {
      gap: 1.5rem 1.25rem;
    }
  }
</style>
