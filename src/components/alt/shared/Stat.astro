---
/*
 * Stat — single number + label, mono tabular for digits.
 * Used in hero stats rows, region cards, bento dashboards.
 */

interface Props {
  /** The number/value, as a string for full control over formatting. */
  value: string;
  /** Description label below the value. */
  label: string;
  /** Layout direction. "stack" = vertical (default), "inline" = horizontal. */
  layout?: "stack" | "inline";
  /** Size variant. */
  size?: "sm" | "md" | "lg";
  class?: string;
}

const {
  value,
  label,
  layout = "stack",
  size = "md",
  class: extraClass = "",
} = Astro.props;
---

<div
  class:list={[
    "alt-stat",
    `alt-stat--${layout}`,
    `alt-stat--${size}`,
    extraClass,
  ]}
>
  <span class="alt-stat__value">{value}</span>
  <span class="alt-stat__label">{label}</span>
</div>

<style>
  .alt-stat {
    display: flex;
  }
  .alt-stat--stack {
    flex-direction: column;
    gap: 0.25rem;
    align-items: flex-start;
  }
  .alt-stat--inline {
    flex-direction: row;
    align-items: baseline;
    gap: 0.5rem;
  }

  .alt-stat__value {
    font-family: var(--f-mono);
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum";
    color: var(--c-ink);
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .alt-stat--sm .alt-stat__value { font-size: 1.25rem; }
  .alt-stat--md .alt-stat__value { font-size: 1.75rem; }
  .alt-stat--lg .alt-stat__value { font-size: 2.5rem; }

  .alt-stat__label {
    color: var(--c-muted);
    font-family: var(--f-body);
    font-variation-settings: var(--fvs-body);
    font-size: 0.8rem;
    line-height: 1.3;
  }
  .alt-stat--sm .alt-stat__label { font-size: 0.7rem; }
  .alt-stat--lg .alt-stat__label { font-size: 0.875rem; }
</style>
