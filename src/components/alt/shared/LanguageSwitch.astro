---
import type { Locale } from "@/i18n/config";
import { getShared } from "@/i18n/alt";

interface Props {
  /** Current locale of the page. */
  locale: Locale;
}

const { locale } = Astro.props;
const t = getShared(locale);

const otherLocale: Locale = locale === "fr" ? "en" : "fr";
const otherShort = otherLocale.toUpperCase();

// EN sits at /, FR sits at /fr/.
const otherUrl = otherLocale === "fr" ? "/fr/" : "/";
---

<a
  href={otherUrl}
  class="alt-langswitch"
  hreflang={otherLocale}
  aria-label={t.nav.languageSwitchLabel}
  rel="alternate"
>
  <span aria-hidden="true">{otherShort}</span>
  <span class="sr-only">{otherLocale === "fr" ? "Français" : "English"}</span>
</a>

<style>
  .alt-langswitch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 32px;
    min-width: 32px;
    padding: 0 0.6rem;
    border-radius: 9999px;
    border: 1px solid var(--c-hairline);
    background: var(--c-surface);
    color: var(--c-muted);
    font-family: var(--f-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: color 200ms cubic-bezier(0.32, 0.72, 0, 1),
                background-color 200ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .alt-langswitch:hover,
  .alt-langswitch:focus-visible {
    color: var(--c-ink);
    background: var(--c-canvas);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
