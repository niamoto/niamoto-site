---
/*
 * Double-bezel container — outer shell + inner core with concentric radii.
 * Pattern from high-end-visual-design §4.A (Doppelrand / nested architecture).
 *
 * Usage:
 *   <DoubleBezel outerRadius="2rem" outerPad="0.375rem">
 *     ...content...
 *   </DoubleBezel>
 */

interface Props {
  /** Outer container border-radius. */
  outerRadius?: string;
  /** Padding inside outer shell, before the inner core. */
  outerPad?: string;
  /** Optional CSS class on the outer shell. */
  class?: string;
  /** Optional CSS class on the inner core. */
  innerClass?: string;
  /** Optional inline style on the inner core. */
  innerStyle?: string;
}

const {
  outerRadius = "2rem",
  outerPad = "0.375rem",
  class: outerClass = "",
  innerClass = "",
  innerStyle = "",
} = Astro.props;

const innerRadius = `calc(${outerRadius} - ${outerPad})`;
---

<div
  class:list={["alt-bezel-outer", outerClass]}
  style={`--bezel-radius: ${outerRadius}; --bezel-pad: ${outerPad};`}
>
  <div
    class:list={["alt-bezel-inner", innerClass]}
    style={`--bezel-inner-radius: ${innerRadius}; ${innerStyle}`}
  >
    <slot />
  </div>
</div>

<style>
  .alt-bezel-outer {
    padding: var(--bezel-pad);
    border-radius: var(--bezel-radius);
    background: var(--c-surface);
    border: 1px solid var(--c-hairline);
  }
  .alt-bezel-inner {
    border-radius: var(--bezel-inner-radius);
    background: var(--c-canvas);
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--c-ink) 4%, transparent);
    overflow: hidden;
  }
</style>
