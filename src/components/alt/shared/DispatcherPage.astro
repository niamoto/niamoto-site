---
import AltLayout from "@/layouts/AltLayout.astro";
import IslandNav from "./IslandNav.astro";
import EyebrowTag from "./EyebrowTag.astro";
import ButtonInButton from "./ButtonInButton.astro";
import FunderGrid from "./FunderGrid.astro";
import FadeUpOnView from "@/components/alt/motion/FadeUpOnView.tsx";
import StaggeredReveal from "@/components/alt/motion/StaggeredReveal.tsx";
import { getShared } from "@/i18n/alt";
import type { Locale } from "@/i18n/config";

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = getShared(locale);

const isFr = locale === "fr";
const altRoot = isFr ? "/fr/alt" : "/alt";

interface VariantCard {
  slug: string;
  theme:
    | "atlas"
    | "field-journal"
    | "methode"
    | "herbarium"
    | "observatory"
    | "portail"
    | "portail-alt"
    | "strate"
    | "manifeste"
    | "cockpit"
    | "silex"
    | "sporee"
    | "canopee"
    | "planche"
    | "frond";
  wave: "alt" | "lab";
  swatches: string[];
  font: string;
  layout: { en: string; fr: string };
  url: string;
}

const variants: VariantCard[] = [
  // ---- Wave 1 (existing) ----
  {
    slug: "atlas",
    theme: "atlas",
    wave: "alt",
    swatches: ["#FDFBF7", "#516B5A", "#A66B3B", "#121212"],
    font: "Fraunces (light, italic accent) + Geist",
    layout: { en: "Editorial Split", fr: "Editorial Split" },
    url: `${altRoot}/atlas`,
  },
  {
    slug: "field-journal",
    theme: "field-journal",
    wave: "alt",
    swatches: ["#F5EEE0", "#3E5F45", "#B8633C", "#0F0F0F"],
    font: "Fraunces (semibold, wonk) + Plus Jakarta Sans",
    layout: { en: "Z-Axis Cascade", fr: "Z-Axis Cascade" },
    url: `${altRoot}/field-journal`,
  },
  {
    slug: "methode",
    theme: "methode",
    wave: "alt",
    swatches: ["#1E2822", "#E8E2D0", "#C08A3E", "#7CA0A8"],
    font: "Cabinet Grotesk + Satoshi",
    layout: { en: "Asymmetrical Bento", fr: "Bento asymetrique" },
    url: `${altRoot}/methode`,
  },
  {
    slug: "herbarium",
    theme: "herbarium",
    wave: "alt",
    swatches: ["#1A1410", "#E8DCC8", "#B87C4F", "#7A8B6F"],
    font: "Fraunces (black, opsz 144) + Geist",
    layout: { en: "Editorial Split + Z-Axis", fr: "Editorial Split + Z-Axis" },
    url: `${altRoot}/herbarium`,
  },
  {
    slug: "observatory",
    theme: "observatory",
    wave: "alt",
    swatches: ["#070908", "#E6EBE7", "#6BD99B", "#7FA7C4"],
    font: "Geist Variable + JetBrains Mono",
    layout: { en: "Ethereal Glass Bento", fr: "Bento verre ethere" },
    url: `${altRoot}/observatory`,
  },
  {
    slug: "portail",
    theme: "portail",
    wave: "alt",
    swatches: ["#F7F4EE", "#3A4F42", "#AE6A3B", "#121414"],
    font: "Clash Display + Geist",
    layout: { en: "Soft Structuralism Split", fr: "Editorial doux + rail portail" },
    url: `${altRoot}/portail`,
  },
  {
    slug: "portail-alt",
    theme: "portail-alt",
    wave: "alt",
    swatches: ["#F4F1EA", "#355848", "#9A5E36", "#151716"],
    font: "Clash Display + Geist",
    layout: { en: "Editorial Proof Sequence", fr: "Séquence éditoriale de preuve" },
    url: `${altRoot}/portail-alt`,
  },
  {
    slug: "strate",
    theme: "strate",
    wave: "alt",
    swatches: ["#EFEBE2", "#4B6150", "#8A6D3D", "#1A1815"],
    font: "Fraunces (display) + Geist",
    layout: { en: "Longform Editorial", fr: "Longform editorial" },
    url: `${altRoot}/strate`,
  },

  // ---- Wave 2 Alt (Niamoto-compatible) ----
  {
    slug: "manifeste",
    theme: "manifeste",
    wave: "alt",
    swatches: ["#F5F1E8", "#1F3A29", "#B07636", "#0F1111"],
    font: "Fraunces (WONK 1) + Geist + JetBrains Mono",
    layout: { en: "CRO Editorial", fr: "CRO editorial" },
    url: `${altRoot}/manifeste`,
  },
  {
    slug: "cockpit",
    theme: "cockpit",
    wave: "alt",
    swatches: ["#0B1220", "#F2F2ED", "#4BAF50", "#E9A53A"],
    font: "Geist Variable + JetBrains Mono",
    layout: { en: "Live Dashboard Bento", fr: "Bento dashboard vivant" },
    url: `${altRoot}/cockpit`,
  },
  {
    slug: "silex",
    theme: "silex",
    wave: "alt",
    swatches: ["#F7F5F0", "#3A3835", "#5C7051", "#F7F5F0"],
    font: "Geist Mono (light) + Fraunces (light)",
    layout: { en: "Radical Minimal", fr: "Minimal radical" },
    url: `${altRoot}/silex`,
  },
  {
    slug: "frond",
    theme: "frond",
    wave: "alt",
    swatches: ["#F5F6F8", "#2E7D32", "#4BAF50", "#5B86B0"],
    font: "Plus Jakarta Sans + JetBrains Mono",
    layout: { en: "Niamoto Design System", fr: "Design System Niamoto" },
    url: `${altRoot}/frond`,
  },

  // ---- Wave 2 Lab (off-rule) ----
  {
    slug: "sporee",
    theme: "sporee",
    wave: "lab",
    swatches: ["#F3EEE2", "#A34B28", "#4A3A6B", "#1A1612"],
    font: "Migra Italic (fallback Fraunces) + Berkeley Mono",
    layout: { en: "Generative p5.js", fr: "Generatif p5.js" },
    url: `${altRoot}/sporee`,
  },
  {
    slug: "canopee",
    theme: "canopee",
    wave: "lab",
    swatches: ["#0A0E0B", "#5E8255", "#C9A86A", "#D4E0D0"],
    font: "Fraunces (display) + Geist Mono",
    layout: { en: "GSAP 5-phase Scroll", fr: "Scroll GSAP 5 phases" },
    url: `${altRoot}/canopee`,
  },
  {
    slug: "planche",
    theme: "planche",
    wave: "lab",
    swatches: ["#EDE4D0", "#3F2A18", "#232F58", "#A03223"],
    font: "IM Fell + Caslon Italic",
    layout: { en: "Horizontal Plate", fr: "Planche horizontale" },
    url: `${altRoot}/planche`,
  },
];

const wave1 = variants.filter((v) =>
  ["atlas", "field-journal", "methode", "herbarium", "observatory", "portail", "portail-alt", "strate"].includes(v.slug)
);
const wave2Alt = variants.filter((v) =>
  ["manifeste", "cockpit", "silex", "frond"].includes(v.slug)
);
const wave2Lab = variants.filter((v) => v.wave === "lab");

const titleText = isFr
  ? "Quatorze directions de design pour niamoto.org"
  : "Fourteen design directions for niamoto.org";

const introText = isFr
  ? "Vague I : huit variantes compatibles avec l'identité Niamoto. Vague II : six explorations plus libres, dont trois en laboratoire hors-règle. Les deux vagues partagent le même contenu ; chacune applique une grammaire visuelle différente."
  : "Wave I: eight variants compatible with Niamoto's identity. Wave II: six looser explorations, three of which break the editorial rule. Both waves share the same subject; each applies a different visual grammar.";
---

<AltLayout
  theme="atlas"
  locale={locale}
  title={isFr ? "Niamoto - Variantes de design" : "Niamoto - Design variants"}
  description={isFr
    ? "Quatorze variantes de landing page pour le site Niamoto, en deux vagues de design."
    : "Fourteen landing page variants for the Niamoto site, in two design waves."}
  slug=""
>
  <a href="#main" class="skip-link">Skip to content</a>
  <IslandNav locale={locale} slug="" />

  <main id="main" class="dispatcher">
    <FadeUpOnView client:visible className="dispatcher__head">
      <EyebrowTag variant="outlined">
        {isFr ? "EXPLORATION DESIGN" : "DESIGN EXPLORATION"}
      </EyebrowTag>
      <h1 class="display dispatcher__title">{titleText}</h1>
      <p class="dispatcher__intro">{introText}</p>
      <div class="dispatcher__cta">
        <ButtonInButton variant="secondary" href={isFr ? "/fr" : "/"}>
          {isFr ? "Site principal" : "Main site"}
        </ButtonInButton>
        <ButtonInButton variant="ghost" href="https://github.com/niamoto/niamoto" target="_blank" rel="noopener">
          GitHub
        </ButtonInButton>
      </div>
    </FadeUpOnView>

    <section class="dispatcher__section" aria-labelledby="wave1-heading">
      <div class="dispatcher__section-head">
        <EyebrowTag variant="outlined">{t.waveLabels.wave1Eyebrow}</EyebrowTag>
        <p id="wave1-heading" class="dispatcher__section-heading">{t.waveLabels.wave1Heading}</p>
      </div>
      <StaggeredReveal client:visible stagger={0.08} y={16} as="ul" className="dispatcher__grid">
        {wave1.map((v) => (
          <li class={`dispatcher-card dispatcher-card--${v.slug}`} data-card-theme={v.theme}>
            <a href={v.url} class="dispatcher-card__link" aria-label={t.variantNames[v.slug as keyof typeof t.variantNames]}>
              <div class="dispatcher-card__preview" aria-hidden="true">
                <div class="dispatcher-card__swatches">
                  {v.swatches.map((c) => (
                    <span class="dispatcher-card__swatch" style={`background: ${c};`}></span>
                  ))}
                </div>
                <span class="dispatcher-card__layout">{isFr ? v.layout.fr : v.layout.en}</span>
              </div>
              <div class="dispatcher-card__meta">
                <h2 class="dispatcher-card__name">
                  {t.variantNames[v.slug as keyof typeof t.variantNames]}
                </h2>
                <p class="dispatcher-card__tagline">
                  {t.variantTaglines[v.slug as keyof typeof t.variantTaglines]}
                </p>
                <p class="dispatcher-card__font">{v.font}</p>
                <span class="dispatcher-card__view">
                  {t.cta.explore} <span aria-hidden="true">&rarr;</span>
                </span>
              </div>
            </a>
          </li>
        ))}
      </StaggeredReveal>
    </section>

    <section class="dispatcher__section" aria-labelledby="wave2alt-heading">
      <div class="dispatcher__section-head">
        <EyebrowTag variant="outlined">{t.waveLabels.wave2AltEyebrow}</EyebrowTag>
        <p id="wave2alt-heading" class="dispatcher__section-heading">{t.waveLabels.wave2AltHeading}</p>
      </div>
      <StaggeredReveal client:visible stagger={0.08} y={16} as="ul" className="dispatcher__grid">
        {wave2Alt.map((v) => (
          <li class={`dispatcher-card dispatcher-card--${v.slug}`} data-card-theme={v.theme}>
            <a href={v.url} class="dispatcher-card__link" aria-label={t.variantNames[v.slug as keyof typeof t.variantNames]}>
              <div class="dispatcher-card__preview" aria-hidden="true">
                <div class="dispatcher-card__swatches">
                  {v.swatches.map((c) => (
                    <span class="dispatcher-card__swatch" style={`background: ${c};`}></span>
                  ))}
                </div>
                <span class="dispatcher-card__layout">{isFr ? v.layout.fr : v.layout.en}</span>
              </div>
              <div class="dispatcher-card__meta">
                <h2 class="dispatcher-card__name">
                  {t.variantNames[v.slug as keyof typeof t.variantNames]}
                </h2>
                <p class="dispatcher-card__tagline">
                  {t.variantTaglines[v.slug as keyof typeof t.variantTaglines]}
                </p>
                <p class="dispatcher-card__font">{v.font}</p>
                <span class="dispatcher-card__view">
                  {t.cta.explore} <span aria-hidden="true">&rarr;</span>
                </span>
              </div>
            </a>
          </li>
        ))}
      </StaggeredReveal>
    </section>

    <section class="dispatcher__section" aria-labelledby="wave2lab-heading">
      <div class="dispatcher__section-head">
        <EyebrowTag variant="outlined">{t.waveLabels.wave2Eyebrow}</EyebrowTag>
        <p id="wave2lab-heading" class="dispatcher__section-heading">{t.waveLabels.wave2Heading}</p>
      </div>
      <StaggeredReveal client:visible stagger={0.08} y={16} as="ul" className="dispatcher__grid">
        {wave2Lab.map((v) => (
          <li class={`dispatcher-card dispatcher-card--${v.slug}`} data-card-theme={v.theme}>
            <a href={v.url} class="dispatcher-card__link" aria-label={t.variantNames[v.slug as keyof typeof t.variantNames]}>
              <div class="dispatcher-card__preview" aria-hidden="true">
                <div class="dispatcher-card__swatches">
                  {v.swatches.map((c) => (
                    <span class="dispatcher-card__swatch" style={`background: ${c};`}></span>
                  ))}
                </div>
                <span class="dispatcher-card__layout">{isFr ? v.layout.fr : v.layout.en}</span>
              </div>
              <div class="dispatcher-card__meta">
                <h2 class="dispatcher-card__name">
                  {t.variantNames[v.slug as keyof typeof t.variantNames]}
                </h2>
                <p class="dispatcher-card__tagline">
                  {t.variantTaglines[v.slug as keyof typeof t.variantTaglines]}
                </p>
                <p class="dispatcher-card__font">{v.font}</p>
                <span class="dispatcher-card__view">
                  {t.cta.explore} <span aria-hidden="true">&rarr;</span>
                </span>
              </div>
            </a>
          </li>
        ))}
      </StaggeredReveal>
    </section>

    <FadeUpOnView client:visible delay={0.1} className="dispatcher__funders">
      <FunderGrid heading={t.legal.builtWith} variant="compact" />
    </FadeUpOnView>
  </main>
</AltLayout>

<style is:global>
  .dispatcher {
    max-width: 1280px;
    margin: 0 auto;
    padding: 7rem 1.5rem 5rem;
  }
  .dispatcher__head {
    max-width: 720px;
    margin-bottom: 4rem;
  }
  .dispatcher__title {
    margin-top: 1.25rem;
    font-size: clamp(2.4rem, 5vw, 4rem);
    color: var(--c-ink);
  }
  .dispatcher__intro {
    margin-top: 1.5rem;
    color: var(--c-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 60ch;
  }
  .dispatcher__cta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* Section separators */
  .dispatcher__section {
    margin-top: 5rem;
  }
  .dispatcher__section:first-of-type {
    margin-top: 0;
  }
  .dispatcher__section-head {
    margin-bottom: 2rem;
  }
  .dispatcher__section-heading {
    font-family: var(--f-display);
    font-variation-settings: var(--fvs-display);
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    letter-spacing: -0.01em;
    color: var(--c-ink);
    max-width: 48ch;
    margin-top: 1rem;
    margin-bottom: 0;
  }

  .dispatcher__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .dispatcher-card {
    border: 1px solid var(--c-hairline);
    border-radius: 1rem;
    overflow: hidden;
    transition: border-color 320ms cubic-bezier(0.32, 0.72, 0, 1),
                transform 320ms cubic-bezier(0.32, 0.72, 0, 1),
                box-shadow 320ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .dispatcher-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--c-ink) 25%, var(--c-hairline));
    box-shadow: 0 16px 40px color-mix(in srgb, var(--c-ink) 8%, transparent);
  }
  .dispatcher-card__link {
    display: grid;
    grid-template-rows: 150px 1fr;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }
  .dispatcher-card__preview {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: space-between;
  }

  /* Wave 1 card preview backgrounds */
  .dispatcher-card--atlas .dispatcher-card__preview { background: #FDFBF7; }
  .dispatcher-card--field-journal .dispatcher-card__preview { background: #F5EEE0; }
  .dispatcher-card--methode .dispatcher-card__preview { background: #1E2822; }
  .dispatcher-card--herbarium .dispatcher-card__preview { background: #1A1410; }
  .dispatcher-card--observatory .dispatcher-card__preview {
    background:
      radial-gradient(18rem 12rem at 18% 82%, rgba(107, 217, 155, 0.22), transparent 62%),
      radial-gradient(16rem 12rem at 86% 14%, rgba(127, 167, 196, 0.2), transparent 64%),
      #070908;
  }
  .dispatcher-card--portail .dispatcher-card__preview { background: #F7F4EE; }
  .dispatcher-card--strate .dispatcher-card__preview { background: #EFEBE2; }

  /* Wave 2 card preview backgrounds */
  .dispatcher-card--manifeste .dispatcher-card__preview { background: #F5F1E8; }
  .dispatcher-card--cockpit .dispatcher-card__preview { background: #0B1220; }
  .dispatcher-card--silex .dispatcher-card__preview { background: #F7F5F0; }
  .dispatcher-card--frond .dispatcher-card__preview {
    background:
      radial-gradient(18rem 12rem at 15% 85%, rgba(46, 125, 50, 0.12), transparent 60%),
      radial-gradient(16rem 12rem at 85% 15%, rgba(91, 134, 176, 0.10), transparent 62%),
      #F5F6F8;
  }
  .dispatcher-card--sporee .dispatcher-card__preview { background: #F3EEE2; }
  .dispatcher-card--canopee .dispatcher-card__preview {
    background:
      radial-gradient(16rem 12rem at 20% 80%, rgba(94, 130, 85, 0.25), transparent 60%),
      #0A0E0B;
  }
  .dispatcher-card--planche .dispatcher-card__preview { background: #EDE4D0; }

  .dispatcher-card__swatches {
    display: flex;
    gap: 0.4rem;
  }
  .dispatcher-card__swatch {
    width: 28px;
    height: 28px;
    border-radius: 0.4rem;
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.04);
  }
  .dispatcher-card__layout {
    font-family: var(--f-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  /* Light preview cards - dark text */
  .dispatcher-card--atlas .dispatcher-card__layout,
  .dispatcher-card--field-journal .dispatcher-card__layout,
  .dispatcher-card--portail .dispatcher-card__layout,
  .dispatcher-card--strate .dispatcher-card__layout,
  .dispatcher-card--manifeste .dispatcher-card__layout,
  .dispatcher-card--silex .dispatcher-card__layout,
  .dispatcher-card--sporee .dispatcher-card__layout,
  .dispatcher-card--planche .dispatcher-card__layout,
  .dispatcher-card--frond .dispatcher-card__layout {
    color: rgba(0, 0, 0, 0.5);
  }
  /* Dark preview cards - light text */
  .dispatcher-card--methode .dispatcher-card__layout,
  .dispatcher-card--herbarium .dispatcher-card__layout,
  .dispatcher-card--observatory .dispatcher-card__layout,
  .dispatcher-card--cockpit .dispatcher-card__layout,
  .dispatcher-card--canopee .dispatcher-card__layout {
    color: rgba(255, 255, 255, 0.55);
  }

  .dispatcher-card__meta {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    background: var(--c-canvas);
  }
  .dispatcher-card__name {
    margin: 0;
    font-family: var(--f-display);
    font-variation-settings: var(--fvs-display);
    font-size: 1.5rem;
    color: var(--c-ink);
    letter-spacing: -0.025em;
  }
  .dispatcher-card__tagline {
    margin: 0;
    color: var(--c-ink);
    opacity: 0.8;
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .dispatcher-card__font {
    margin: 0;
    color: var(--c-muted);
    font-family: var(--f-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
  }
  .dispatcher-card__view {
    margin-top: auto;
    color: var(--c-accent);
    font-family: var(--f-body);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .dispatcher__funders {
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 1px solid var(--c-hairline);
  }

  @media (max-width: 1100px) {
    .dispatcher__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 640px) {
    .dispatcher__grid {
      grid-template-columns: 1fr;
    }
    .dispatcher-card__preview {
      min-height: 120px;
    }
  }
</style>
