---
import EyebrowTag from "@/components/alt/shared/EyebrowTag.astro";
import ButtonInButton from "@/components/alt/shared/ButtonInButton.astro";
import FadeUpOnView from "@/components/alt/motion/FadeUpOnView.tsx";

interface Props {
  eyebrow: string;
  titleLines: readonly string[];
  italicWord: string;
  sub: string;
  ctaPrimary: string;
  ctaSecondary: string;
  /** Right-side region list slot — passed as children. */
}
const { eyebrow, titleLines, italicWord, sub, ctaPrimary, ctaSecondary } = Astro.props;

// Helper: render a line with the italic word marked by <em>.
function highlightItalic(line: string, italic: string): { before: string; em: string | null; after: string } {
  if (!italic) return { before: line, em: null, after: "" };
  const idx = line.indexOf(italic);
  if (idx === -1) return { before: line, em: null, after: "" };
  return {
    before: line.slice(0, idx),
    em: italic,
    after: line.slice(idx + italic.length),
  };
}
---

<section class="atlas-hero">
  <div class="atlas-hero__inner">
    <FadeUpOnView client:visible delay={0.05} className="atlas-hero__left">
      <EyebrowTag variant="outlined" class="atlas-hero__eyebrow">
        {eyebrow}
      </EyebrowTag>

      <h1 class="display atlas-hero__title">
        {titleLines.map((line, i) => {
          const parts = highlightItalic(line, italicWord);
          return (
            <span class="atlas-hero__line">
              {parts.before}
              {parts.em && <em>{parts.em}</em>}
              {parts.after}
              {i < titleLines.length - 1 ? <br /> : null}
            </span>
          );
        })}
      </h1>

      <p class="atlas-hero__sub">{sub}</p>

      <div class="atlas-hero__cta">
        <ButtonInButton variant="primary" href="#install">{ctaPrimary}</ButtonInButton>
        <ButtonInButton variant="secondary" href="#regions">{ctaSecondary}</ButtonInButton>
      </div>
    </FadeUpOnView>

    <FadeUpOnView client:visible delay={0.18} className="atlas-hero__right">
      <slot />
    </FadeUpOnView>
  </div>
</section>

<style>
  .atlas-hero {
    width: 100%;
    padding: 8rem 1.5rem 5rem;
  }
  .atlas-hero__inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .atlas-hero__eyebrow {
    margin-bottom: 1.75rem;
  }
  .atlas-hero__title {
    font-size: clamp(2.6rem, 6vw, 5rem);
    color: var(--c-ink);
  }
  .atlas-hero__line {
    display: block;
  }
  .atlas-hero__title em {
    color: var(--c-accent);
    font-style: italic;
    font-variation-settings: "opsz" 24, "wght" 400, "WONK" 1, "SOFT" 50;
  }
  .atlas-hero__sub {
    margin-top: 1.6rem;
    max-width: 36ch;
    color: var(--c-muted);
    font-size: 1.05rem;
    line-height: 1.55;
  }
  .atlas-hero__cta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  @media (max-width: 900px) {
    .atlas-hero {
      padding: 6.5rem 1rem 3rem;
    }
    .atlas-hero__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .atlas-hero__sub {
      max-width: 52ch;
    }
  }
</style>
