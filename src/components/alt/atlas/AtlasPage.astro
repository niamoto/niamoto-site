---
import AltLayout from "@/layouts/AltLayout.astro";
import IslandNav from "@/components/alt/shared/IslandNav.astro";
import HeroEditorialSplit from "./HeroEditorialSplit.astro";
import RegionList from "./RegionList.astro";
import PillarGrid from "./PillarGrid.astro";
import ClosingNote from "./ClosingNote.astro";
import type { Locale } from "@/i18n/config";
import enCopy from "@/i18n/alt/atlas.en";
import frCopy from "@/i18n/alt/atlas.fr";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = locale === "fr" ? frCopy : enCopy;
---

<AltLayout
  theme="atlas"
  locale={locale}
  title={t.meta.title}
  description={t.meta.description}
  slug="atlas"
>
  <a href="#main" class="skip-link">Skip to content</a>
  <IslandNav locale={locale} slug="atlas" />

  <main id="main">
    <HeroEditorialSplit
      eyebrow={t.hero.eyebrow}
      titleLines={t.hero.title}
      italicWord={t.hero.titleItalicWord}
      sub={t.hero.sub}
      ctaPrimary={t.hero.cta}
      ctaSecondary={t.hero.ctaSecondary}
    >
      <RegionList intro={t.regions.intro} items={t.regions.items} />
    </HeroEditorialSplit>

    <section id="regions" aria-label={t.regions.heading} class="atlas-regions-section">
      <div class="atlas-regions-section__inner">
        <p class="atlas-regions-section__heading display">{t.regions.heading}</p>
      </div>
    </section>

    <PillarGrid heading={t.pillars.heading} items={t.pillars.items} />

    <ClosingNote
      eyebrow={t.closing.eyebrow}
      title={t.closing.title}
      body={t.closing.body}
      ctaPrimary={t.closing.ctaPrimary}
      ctaSecondary={t.closing.ctaSecondary}
      discussions={t.closing.discussions}
      changelog={t.closing.changelog}
      fundersHeading={t.funders.heading}
    />
  </main>
</AltLayout>

<style>
  .atlas-regions-section {
    padding: 1.5rem 1.5rem 0;
  }
  .atlas-regions-section__inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .atlas-regions-section__heading {
    font-size: 0.78rem;
    font-family: var(--f-mono);
    color: var(--c-muted);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
</style>
