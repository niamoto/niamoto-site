---
import StaggeredReveal from "@/components/alt/motion/StaggeredReveal.tsx";

interface PillarItem {
  kicker: string;
  title: string;
  body: string;
  snippet: string | null;
}

interface Props {
  heading: string;
  items: readonly PillarItem[];
}

const { heading, items } = Astro.props;
---

<section class="atlas-pillars">
  <div class="atlas-pillars__inner">
    <header class="atlas-pillars__header">
      <h2 class="display atlas-pillars__heading">{heading}</h2>
    </header>

    <StaggeredReveal client:visible stagger={0.1} y={18} as="div" className="atlas-pillars__grid">
      {items.map((p) => (
        <article class="atlas-pillar">
          <span class="atlas-pillar__kicker">{p.kicker}</span>
          <h3 class="atlas-pillar__title">{p.title}</h3>
          <p class="atlas-pillar__body">{p.body}</p>
          {p.snippet && (
            <pre class="atlas-pillar__snippet"><code>{p.snippet}</code></pre>
          )}
        </article>
      ))}
    </StaggeredReveal>
  </div>
</section>

<style>
  .atlas-pillars {
    width: 100%;
    padding: 6rem 1.5rem;
  }
  .atlas-pillars__inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .atlas-pillars__header {
    margin-bottom: 3rem;
    max-width: 32ch;
  }
  .atlas-pillars__heading {
    font-size: clamp(2rem, 4vw, 3.25rem);
    color: var(--c-ink);
  }
  .atlas-pillars__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    border-top: 1px solid var(--c-hairline);
  }
  .atlas-pillar {
    padding: 2rem 1.5rem 2rem 0;
    border-right: 1px solid var(--c-hairline);
  }
  .atlas-pillar:last-child {
    border-right: none;
  }
  .atlas-pillar__kicker {
    font-family: var(--f-mono);
    font-size: 0.75rem;
    color: var(--c-muted);
    letter-spacing: 0.14em;
  }
  .atlas-pillar__title {
    margin: 0.6rem 0 0.85rem;
    font-family: var(--f-display);
    font-variation-settings: var(--fvs-display);
    font-size: 1.3rem;
    color: var(--c-ink);
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .atlas-pillar__body {
    margin: 0;
    color: var(--c-ink);
    opacity: 0.78;
    font-size: 0.95rem;
    line-height: 1.55;
    max-width: 42ch;
  }
  .atlas-pillar__snippet {
    margin: 1.25rem 0 0;
    padding: 0.85rem 1rem;
    background: color-mix(in srgb, var(--c-ink) 92%, transparent);
    color: color-mix(in srgb, var(--c-canvas) 95%, transparent);
    border-radius: 0.5rem;
    font-family: var(--f-mono);
    font-size: 0.78rem;
    line-height: 1.55;
    overflow: auto;
  }

  @media (max-width: 900px) {
    .atlas-pillars__grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .atlas-pillar {
      border-right: none;
      border-bottom: 1px solid var(--c-hairline);
      padding: 1.75rem 0;
    }
    .atlas-pillar:last-child {
      border-bottom: none;
    }
  }
</style>
