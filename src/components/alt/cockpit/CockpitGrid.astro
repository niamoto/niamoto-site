---
import KPITile from "./KPITile.astro";
import SparkCard from "./SparkCard.astro";

interface KPI {
  label: string;
  value: string;
  delta?: string;
  status?: "ok" | "amber" | "muted";
}
interface Spark {
  label: string;
  value: string;
  delta: string;
  values: readonly number[];
  tone: "emerald" | "amber";
}
interface Props {
  kpis: readonly KPI[];
  sparks: readonly Spark[];
}
const { kpis, sparks } = Astro.props;
---

<div class="cockpit-grid">
  {kpis.slice(0, 4).map((k) => <KPITile {...k} />)}
  <SparkCard {...sparks[0]} index={0} />
  <SparkCard {...sparks[1]} index={1} />
  {kpis.slice(4, 10).map((k) => <KPITile {...k} />)}
</div>
