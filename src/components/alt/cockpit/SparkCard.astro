---
interface Props {
  label: string;
  value: string;
  delta: string;
  values: readonly number[];
  tone?: "emerald" | "amber";
  /** Unique index to avoid duplicate SVG gradient ids when rendering multiple cards. */
  index?: number;
}
const { label, value, delta, values, tone = "emerald", index = 0 } = Astro.props;

// Normalize values: x [0..100], y [0..80] (inverted: high = top).
const max = Math.max(...values);
const min = Math.min(...values);
const range = max - min || 1;
const points = values.map((v, i) => {
  const x = (i / (values.length - 1)) * 100;
  const y = 80 - ((v - min) / range) * 72; // 72 = 80 - 8 margin top
  return `${x.toFixed(1)},${y.toFixed(1)}`;
});
const path = `M ${points.join(" L ")}`;
const area = `${path} L 100,80 L 0,80 Z`;
const lastX = 100;
const lastY = 80 - ((values[values.length - 1] - min) / range) * 72;
const toneClass = tone === "amber" ? "cockpit-spark--amber" : "";
const gradId = `cockpit-spark-grad-${index}`;
const gradColor = tone === "amber" ? "#E9A53A" : "#4BAF50";
---

<article class={`cockpit-spark ${toneClass}`}>
  <div class="cockpit-spark__meta">
    <p class="cockpit-tile__label">{label}</p>
    <p class="cockpit-spark__value">{value}</p>
    <p class="cockpit-tile__delta">{delta}</p>
  </div>
  <svg
    class="cockpit-spark__svg"
    viewBox="0 0 100 80"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id={gradId} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%"   stop-color={gradColor} stop-opacity="0.35" />
        <stop offset="100%" stop-color={gradColor} stop-opacity="0" />
      </linearGradient>
    </defs>
    <path class="cockpit-spark__area" d={area} style={`fill: url(#${gradId})`} />
    <path class="cockpit-spark__line" d={path} />
    <circle class="cockpit-spark__dot" cx={lastX} cy={lastY.toFixed(1)} r="2.2" />
  </svg>
</article>
