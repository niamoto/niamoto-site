---
interface Props {
  kicker: string;
  line1: string;
  line2: string;
  secondary: string;
}

const { kicker, line1, line2, secondary } = Astro.props;
---

<article class="obs-tile obs-range">
  <span class="alt-mono obs-range__kicker">{kicker}</span>

  <svg class="obs-range__visual" viewBox="0 0 300 180" fill="none" aria-hidden="true">
    <defs>
      <radialGradient id="obsRangeOrb" cx="50%" cy="50%" r="55%">
        <stop offset="0%" stop-color="#6BD99B" stop-opacity="0.55" />
        <stop offset="55%" stop-color="#6BD99B" stop-opacity="0.12" />
        <stop offset="100%" stop-color="#6BD99B" stop-opacity="0" />
      </radialGradient>
      <radialGradient id="obsSteelOrb" cx="50%" cy="50%" r="55%">
        <stop offset="0%" stop-color="#7FA7C4" stop-opacity="0.35" />
        <stop offset="100%" stop-color="#7FA7C4" stop-opacity="0" />
      </radialGradient>
    </defs>

    {/* Baseline grid */}
    {Array.from({ length: 12 }).map((_, i) => (
      <line
        x1="0" y1={i * 15 + 2} x2="300" y2={i * 15 + 2}
        stroke="#E6EBE7" stroke-width="1" stroke-opacity="0.04"
      />
    ))}
    {Array.from({ length: 20 }).map((_, i) => (
      <line
        x1={i * 15 + 2} y1="0" x2={i * 15 + 2} y2="180"
        stroke="#E6EBE7" stroke-width="1" stroke-opacity="0.04"
      />
    ))}

    {/* South Pacific island cluster - abstract dot blobs. */}
    <circle cx="210" cy="105" r="58" fill="url(#obsRangeOrb)" />
    <circle cx="60"  cy="60"  r="38" fill="url(#obsSteelOrb)" />
    <circle cx="45"  cy="138" r="28" fill="url(#obsSteelOrb)" />

    {/* Stylised islands (NC shape) */}
    <path
      d="M 188 74 Q 205 68 225 78 Q 248 94 258 118 Q 245 130 215 128 Q 195 120 185 100 Q 180 85 188 74 Z"
      fill="none" stroke="#6BD99B" stroke-width="1.2" stroke-opacity="0.8"
    />
    <circle cx="210" cy="105" r="2" fill="#6BD99B" />
    <circle cx="230" cy="120" r="1.5" fill="#6BD99B" opacity="0.6" />
    <circle cx="198" cy="92" r="1.5" fill="#6BD99B" opacity="0.6" />

    {/* Upcoming deployments - muted dots */}
    <circle cx="60"  cy="60"  r="2" fill="#7FA7C4" opacity="0.7" />
    <circle cx="45"  cy="138" r="2" fill="#7FA7C4" opacity="0.7" />
  </svg>

  <div class="obs-range__meta">
    <p class="obs-range__line">
      <span class="obs-range__line1">{line1}</span>
      <span class="obs-range__line2 display">{line2}</span>
    </p>
    <p class="obs-range__secondary alt-mono">{secondary}</p>
  </div>
</article>

<style>
  .obs-range {
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 100%;
    position: relative;
    overflow: hidden;
  }
  .obs-range__kicker {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-muted);
  }
  .obs-range__visual {
    width: 100%;
    height: auto;
    margin: 0.5rem 0;
  }
  .obs-range__line {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .obs-range__line1 {
    font-family: var(--f-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-muted);
  }
  .obs-range__line2 {
    font-size: 1.45rem;
    color: var(--c-ink);
    letter-spacing: -0.02em;
  }
  .obs-range__secondary {
    margin: 0;
    font-size: 0.72rem;
    color: var(--c-muted);
    line-height: 1.5;
  }
</style>
