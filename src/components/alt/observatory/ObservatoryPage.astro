---
import AltLayout from "@/layouts/AltLayout.astro";
import IslandNav from "@/components/alt/shared/IslandNav.astro";
import HeroObservatory from "./HeroObservatory.astro";
import TelemetryBento from "./TelemetryBento.astro";
import PillarStack from "./PillarStack.astro";
import ClosingNote from "./ClosingNote.astro";
import type { Locale } from "@/i18n/config";
import enCopy from "@/i18n/alt/observatory.en";
import frCopy from "@/i18n/alt/observatory.fr";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = locale === "fr" ? frCopy : enCopy;
---

<AltLayout
  theme="observatory"
  locale={locale}
  title={t.meta.title}
  description={t.meta.description}
  slug="observatory"
>
  <a href="#main" class="skip-link">Skip to content</a>
  <IslandNav locale={locale} slug="observatory" />

  <main id="main">
    <HeroObservatory
      eyebrow={t.hero.eyebrow}
      titleLines={t.hero.titleLines}
      sub={t.hero.sub}
      ctaPrimary={t.hero.cta}
      ctaSecondary={t.hero.ctaSecondary}
    />

    <TelemetryBento
      heading={t.telemetry.heading}
      sub={t.telemetry.sub}
      pulseKicker={t.telemetry.pulse.kicker}
      pulseLines={t.telemetry.pulse.lines}
      statsKicker={t.telemetry.stats.kicker}
      statsItems={t.telemetry.stats.items}
      mapKicker={t.telemetry.map.kicker}
      mapLine1={t.telemetry.map.line1}
      mapLine2={t.telemetry.map.line2}
      mapSecondary={t.telemetry.map.secondary}
      terminalKicker={t.telemetry.terminal.kicker}
      terminalLines={t.telemetry.terminal.lines}
      locale={locale}
    />

    <PillarStack
      heading={t.pillars.heading}
      items={t.pillars.items}
      locale={locale}
    />

    <ClosingNote
      eyebrow={t.closing.eyebrow}
      title={t.closing.title}
      body={t.closing.body}
      ctaPrimary={t.closing.ctaPrimary}
      ctaSecondary={t.closing.ctaSecondary}
      fundersHeading={t.funders.heading}
    />
  </main>
</AltLayout>
