---
import EyebrowTag from "@/components/alt/shared/EyebrowTag.astro";
import ButtonInButton from "@/components/alt/shared/ButtonInButton.astro";
import FadeUpOnView from "@/components/alt/motion/FadeUpOnView.tsx";

interface Props {
  eyebrow: string;
  titleLines: readonly string[];
  sub: string;
  ctaPrimary: string;
  ctaSecondary: string;
}

const { eyebrow, titleLines, sub, ctaPrimary, ctaSecondary } = Astro.props;
---

<section class="obs-hero" aria-label="Hero">
  <FadeUpOnView client:visible blur={0} className="obs-hero__inner">
    <EyebrowTag variant="outlined">
      <span class="obs-pulse" aria-hidden="true"></span>
      <span>{eyebrow}</span>
    </EyebrowTag>

    <h1 class="display obs-hero__title">
      {titleLines.map((line, i) => (
        <span class="obs-hero__line" style={`--obs-line-index: ${i};`}>{line}</span>
      ))}
    </h1>

    <p class="obs-hero__sub">{sub}</p>

    <div class="obs-hero__cta">
      <ButtonInButton variant="primary" href="https://github.com/niamoto/niamoto">
        {ctaPrimary}
      </ButtonInButton>
      <ButtonInButton variant="secondary" href="https://niamoto.github.io/niamoto-nouvelle-caledonie-2025/" target="_blank" rel="noopener">
        {ctaSecondary}
      </ButtonInButton>
    </div>
  </FadeUpOnView>
</section>

<style>
  .obs-hero {
    padding: 10rem 1.5rem 5rem;
    max-width: 1280px;
    margin: 0 auto;
  }
  .obs-hero__inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 56rem;
  }
  .obs-hero__title {
    display: flex;
    flex-direction: column;
    font-size: clamp(3rem, 8vw, 7rem);
    letter-spacing: -0.045em;
    font-variation-settings: "wght" 500;
    color: var(--c-ink);
  }
  .obs-hero__line {
    display: block;
  }
  .obs-hero__line:nth-child(2) {
    color: var(--c-muted);
  }
  .obs-hero__sub {
    max-width: 42rem;
    color: var(--c-muted);
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    line-height: 1.6;
    margin: 0;
  }
  .obs-hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  @media (max-width: 768px) {
    .obs-hero {
      padding: 7rem 1rem 3.5rem;
    }
  }
</style>
