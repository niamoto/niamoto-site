---
import EyebrowTag from "@/components/alt/shared/EyebrowTag.astro";
import PulseTicker from "./PulseTicker.astro";
import StatsCard from "./StatsCard.astro";
import RangeCard from "./RangeCard.astro";
import TerminalCard from "./TerminalCard.astro";
import FadeUpOnView from "@/components/alt/motion/FadeUpOnView.tsx";

interface TickerLine {
  dot: boolean;
  label: string;
  sub: string;
  time: string;
}
interface StatItem { value: number; label: string; suffix?: string }

interface Props {
  heading: string;
  sub: string;
  pulseKicker: string;
  pulseLines: readonly TickerLine[];
  statsKicker: string;
  statsItems: readonly StatItem[];
  mapKicker: string;
  mapLine1: string;
  mapLine2: string;
  mapSecondary: string;
  terminalKicker: string;
  terminalLines: readonly string[];
  locale: "en" | "fr";
}

const {
  heading, sub,
  pulseKicker, pulseLines,
  statsKicker, statsItems,
  mapKicker, mapLine1, mapLine2, mapSecondary,
  terminalKicker, terminalLines,
  locale,
} = Astro.props;
---

<section class="obs-telemetry" aria-label={heading}>
  <FadeUpOnView client:visible className="obs-telemetry__head">
    <EyebrowTag variant="outlined">{locale === "fr" ? "TELEMETRIE" : "TELEMETRY"}</EyebrowTag>
    <h2 class="display obs-telemetry__heading">{heading}</h2>
    <p class="obs-telemetry__sub">{sub}</p>
  </FadeUpOnView>

  <div class="obs-telemetry__grid">
    <div class="obs-telemetry__cell obs-telemetry__cell--pulse">
      <PulseTicker kicker={pulseKicker} lines={pulseLines} />
    </div>
    <div class="obs-telemetry__cell obs-telemetry__cell--stats">
      <StatsCard kicker={statsKicker} items={statsItems} locale={locale} />
    </div>
    <div class="obs-telemetry__cell obs-telemetry__cell--range">
      <RangeCard kicker={mapKicker} line1={mapLine1} line2={mapLine2} secondary={mapSecondary} />
    </div>
    <div class="obs-telemetry__cell obs-telemetry__cell--terminal">
      <TerminalCard kicker={terminalKicker} lines={terminalLines} />
    </div>
  </div>
</section>

<style>
  .obs-telemetry {
    padding: 4rem 1.5rem 6rem;
    max-width: 1280px;
    margin: 0 auto;
  }
  .obs-telemetry__head {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 48rem;
    margin-bottom: 3rem;
  }
  .obs-telemetry__heading {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-variation-settings: "wght" 500;
    color: var(--c-ink);
  }
  .obs-telemetry__sub {
    margin: 0;
    color: var(--c-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .obs-telemetry__grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    grid-template-rows: auto auto;
    gap: 1.25rem;
  }
  .obs-telemetry__cell {
    display: flex;
  }
  .obs-telemetry__cell--pulse    { grid-column: span 7; grid-row: 1; }
  .obs-telemetry__cell--stats    { grid-column: span 5; grid-row: 1; }
  .obs-telemetry__cell--range    { grid-column: span 5; grid-row: 2; }
  .obs-telemetry__cell--terminal { grid-column: span 7; grid-row: 2; }

  .obs-telemetry__cell > * {
    flex: 1;
  }

  @media (max-width: 1024px) {
    .obs-telemetry__cell--pulse,
    .obs-telemetry__cell--stats,
    .obs-telemetry__cell--range,
    .obs-telemetry__cell--terminal {
      grid-column: span 12;
      grid-row: auto;
    }
  }

  @media (max-width: 768px) {
    .obs-telemetry {
      padding: 2rem 1rem 4rem;
    }
  }
</style>
