---
import InfiniteTypewriter from "@/components/alt/motion/InfiniteTypewriter.tsx";

interface Props {
  kicker: string;
  lines: readonly string[];
}

const { kicker, lines } = Astro.props;
---

<article class="obs-tile obs-terminal">
  <header class="obs-terminal__header">
    <div class="obs-terminal__chrome">
      <span class="obs-terminal__dot"></span>
      <span class="obs-terminal__dot"></span>
      <span class="obs-terminal__dot"></span>
    </div>
    <span class="obs-terminal__kicker alt-mono">{kicker}</span>
  </header>

  <div class="obs-terminal__body">
    <InfiniteTypewriter
      client:visible
      lines={[...lines]}
      className="obs-terminal__type"
      typeMs={45}
      holdMs={1500}
    />
  </div>
</article>

<style>
  .obs-terminal {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 100%;
  }
  .obs-terminal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--c-hairline);
  }
  .obs-terminal__chrome {
    display: inline-flex;
    gap: 0.35rem;
  }
  .obs-terminal__dot {
    width: 9px;
    height: 9px;
    border-radius: 9999px;
    background: var(--c-surface);
    border: 1px solid var(--c-hairline);
  }
  .obs-terminal__dot:nth-child(1) { background: rgba(107, 217, 155, 0.35); }
  .obs-terminal__dot:nth-child(2) { background: rgba(127, 167, 196, 0.35); }
  .obs-terminal__kicker {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-muted);
  }
  .obs-terminal__body {
    flex: 1;
    font-family: var(--f-mono);
    font-size: 0.95rem;
    color: var(--c-ink);
    line-height: 1.5;
  }
  .obs-terminal__type {
    margin: 0;
    white-space: pre-wrap;
  }
</style>
