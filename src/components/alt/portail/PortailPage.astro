---
import AltLayout from "@/layouts/AltLayout.astro";
import IslandNav from "@/components/alt/shared/IslandNav.astro";
import HeroPortail from "./HeroPortail.astro";
import PortalRail from "./PortalRail.astro";
import ProcessStrip from "./ProcessStrip.astro";
import ClosingNote from "./ClosingNote.astro";
import type { Locale } from "@/i18n/config";
import enCopy from "@/i18n/alt/portail.en";
import frCopy from "@/i18n/alt/portail.fr";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = locale === "fr" ? frCopy : enCopy;
---

<AltLayout
  theme="portail"
  locale={locale}
  title={t.meta.title}
  description={t.meta.description}
  slug="portail"
>
  <a href="#main" class="skip-link">Skip to content</a>
  <IslandNav locale={locale} slug="portail" />

  <main id="main">
    <HeroPortail
      eyebrow={t.hero.eyebrow}
      titleLines={t.hero.titleLines}
      sub={t.hero.sub}
      ctaPrimary={t.hero.cta}
      ctaSecondary={t.hero.ctaSecondary}
    />

    <PortalRail
      kicker={t.rail.kicker}
      heading={t.rail.heading}
      sub={t.rail.sub}
      cards={t.rail.cards}
    />

    <ProcessStrip
      kicker={t.process.kicker}
      heading={t.process.heading}
      items={t.process.items}
    />

    <ClosingNote
      eyebrow={t.closing.eyebrow}
      title={t.closing.title}
      body={t.closing.body}
      ctaPrimary={t.closing.ctaPrimary}
      ctaSecondary={t.closing.ctaSecondary}
      fundersHeading={t.funders.heading}
    />
  </main>
</AltLayout>
