---
/*
 * Stylized SVG mockup of the Niamoto single-taxon sheet for Amborella trichopoda.
 * Stands in for a real screenshot; evokes the shape of the page without claiming
 * to be an exact render. Intended to be viewed inside a portal-card figure.
 */
---

<svg
  class="amb-mockup"
  viewBox="0 0 600 420"
  preserveAspectRatio="xMidYMin slice"
  role="img"
  aria-label="Schematic mockup of the Amborella trichopoda taxon sheet"
>
  <defs>
    <linearGradient id="ambCanvas" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"  stop-color="#F7F4EE" />
      <stop offset="100%" stop-color="#EFEBE2" />
    </linearGradient>
    <radialGradient id="ambMapOrb" cx="55%" cy="55%" r="50%">
      <stop offset="0%"  stop-color="#3A4F42" stop-opacity="0.22" />
      <stop offset="100%" stop-color="#3A4F42" stop-opacity="0" />
    </radialGradient>
  </defs>

  <rect width="600" height="420" fill="url(#ambCanvas)" />

  {/* Header band */}
  <rect x="0" y="0" width="600" height="52" fill="#F7F4EE" />
  <line x1="0" y1="52" x2="600" y2="52" stroke="#3A4F42" stroke-opacity="0.11" />
  <circle cx="24" cy="26" r="6" fill="#3A4F42" />
  <rect x="40" y="22" width="72" height="8" rx="2" fill="#121414" fill-opacity="0.7" />
  <rect x="540" y="20" width="40" height="12" rx="6" fill="#3A4F42" fill-opacity="0.12" />

  {/* Breadcrumb */}
  <rect x="24" y="72" width="120" height="6" rx="1" fill="#121414" fill-opacity="0.35" />

  {/* Title block */}
  <text x="24" y="112" font-family="serif" font-style="italic" font-size="28" font-weight="500" fill="#121414">Amborella trichopoda</text>
  <text x="24" y="132" font-family="monospace" font-size="9" fill="#121414" fill-opacity="0.45" letter-spacing="1.4">AMBORELLACEAE  -  ENDEMIQUE NC</text>

  {/* Stat row */}
  <g transform="translate(24, 154)">
    <rect x="0"   y="0" width="124" height="48" rx="6" fill="#121414" fill-opacity="0.03" stroke="#121414" stroke-opacity="0.09" />
    <text x="12" y="18" font-family="monospace" font-size="8" fill="#121414" fill-opacity="0.5">OCCURRENCES</text>
    <text x="12" y="38" font-family="monospace" font-weight="500" font-size="18" fill="#121414">127</text>

    <rect x="132" y="0" width="124" height="48" rx="6" fill="#121414" fill-opacity="0.03" stroke="#121414" stroke-opacity="0.09" />
    <text x="144" y="18" font-family="monospace" font-size="8" fill="#121414" fill-opacity="0.5">PLACETTES</text>
    <text x="144" y="38" font-family="monospace" font-weight="500" font-size="18" fill="#121414">42</text>

    <rect x="264" y="0" width="124" height="48" rx="6" fill="#3A4F42" fill-opacity="0.14" stroke="#3A4F42" stroke-opacity="0.25" />
    <text x="276" y="18" font-family="monospace" font-size="8" fill="#3A4F42" fill-opacity="0.8">ENDEMISME</text>
    <text x="276" y="38" font-family="monospace" font-weight="500" font-size="18" fill="#3A4F42">100 %</text>

    <rect x="396" y="0" width="124" height="48" rx="6" fill="#121414" fill-opacity="0.03" stroke="#121414" stroke-opacity="0.09" />
    <text x="408" y="18" font-family="monospace" font-size="8" fill="#121414" fill-opacity="0.5">SURFACE TERR.</text>
    <text x="408" y="38" font-family="monospace" font-weight="500" font-size="18" fill="#121414">2.3 m²</text>
  </g>

  {/* Map card */}
  <g transform="translate(24, 220)">
    <rect x="0" y="0" width="336" height="180" rx="8" fill="#F7F4EE" stroke="#121414" stroke-opacity="0.08" />
    <text x="14" y="22" font-family="monospace" font-size="8" fill="#121414" fill-opacity="0.5" letter-spacing="1.4">CARTE D'OCCURRENCES</text>
    <rect x="14" y="34" width="308" height="128" rx="4" fill="#121414" fill-opacity="0.025" />

    {/* Abstract NC island outline */}
    <path d="M 120 70 Q 155 58 200 68 Q 250 82 290 110 Q 275 135 230 140 Q 180 130 145 110 Q 115 92 120 70 Z"
          fill="url(#ambMapOrb)" stroke="#3A4F42" stroke-opacity="0.55" stroke-width="1" />
    {/* Occurrence dots */}
    <circle cx="180" cy="90"  r="2.5" fill="#3A4F42" />
    <circle cx="210" cy="100" r="2.5" fill="#3A4F42" />
    <circle cx="165" cy="102" r="2.5" fill="#3A4F42" />
    <circle cx="240" cy="118" r="2.5" fill="#3A4F42" />
    <circle cx="195" cy="122" r="2.5" fill="#3A4F42" />
    <circle cx="260" cy="128" r="2.5" fill="#AE6A3B" />
    <circle cx="145" cy="120" r="2.5" fill="#3A4F42" />
    <circle cx="225" cy="85" r="2.5" fill="#3A4F42" />
  </g>

  {/* Chart card */}
  <g transform="translate(372, 220)">
    <rect x="0" y="0" width="204" height="180" rx="8" fill="#F7F4EE" stroke="#121414" stroke-opacity="0.08" />
    <text x="14" y="22" font-family="monospace" font-size="8" fill="#121414" fill-opacity="0.5" letter-spacing="1.4">DIAMETRE / DISTRIBUTION</text>

    {/* Histogram bars */}
    <g transform="translate(14, 60)">
      <rect x="0"   y="70" width="22" height="30" fill="#3A4F42" fill-opacity="0.25" />
      <rect x="26"  y="50" width="22" height="50" fill="#3A4F42" fill-opacity="0.45" />
      <rect x="52"  y="25" width="22" height="75" fill="#3A4F42" fill-opacity="0.75" />
      <rect x="78"  y="14" width="22" height="86" fill="#3A4F42" />
      <rect x="104" y="32" width="22" height="68" fill="#3A4F42" fill-opacity="0.75" />
      <rect x="130" y="58" width="22" height="42" fill="#3A4F42" fill-opacity="0.45" />
      <rect x="156" y="82" width="22" height="18" fill="#3A4F42" fill-opacity="0.22" />
    </g>
    <line x1="14" y1="160" x2="190" y2="160" stroke="#121414" stroke-opacity="0.2" />
  </g>
</svg>

<style>
  .amb-mockup {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
