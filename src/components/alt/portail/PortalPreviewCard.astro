---
import AmborellaMockup from "./AmborellaMockup.astro";

interface Props {
  code: string;
  name: string;
  role: string;
  body: string;
  image: string | null;
  alt: string;
  href: string;
  tiltClass: string;
}

const { code, name, role, body, image, alt, href, tiltClass } = Astro.props;
---

<a
  class:list={["portal-card", tiltClass]}
  href={href}
  target="_blank"
  rel="noopener"
  aria-label={alt}
>
  <div class="portal-card__header">
    <span class="portal-card__code portal-caption">{code}</span>
    <span class="portal-card__role portal-caption">{role}</span>
  </div>

  <div class="portal-card__name-row">
    <h3 class="portal-card__name">{name}</h3>
    <span class="portal-card__arrow" aria-hidden="true">
      <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 13 L13 3" />
        <path d="M6 3 L13 3 L13 10" />
      </svg>
    </span>
  </div>

  <p class="portal-card__body">{body}</p>

  <figure class="portal-card__figure">
    {image ? (
      <img src={image} alt={alt} loading="lazy" decoding="async" />
    ) : (
      <AmborellaMockup />
    )}
  </figure>
</a>

<style>
  .portal-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1.5rem 0;
    text-decoration: none;
    color: inherit;
    min-height: 520px;
    transform-origin: center top;
  }
  .portal-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .portal-card__name-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
  }
  .portal-card__name {
    margin: 0;
    font-family: var(--f-mono);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--c-ink);
  }
  .portal-card__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--c-ink) 6%, transparent);
    color: var(--c-ink);
    transition: transform 300ms cubic-bezier(0.32, 0.72, 0, 1),
                background-color 300ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .portal-card:hover .portal-card__arrow {
    transform: translate(2px, -1px);
    background: var(--c-ink);
    color: var(--c-canvas);
  }
  .portal-card__body {
    margin: 0.75rem 0 1.25rem;
    color: var(--c-muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }
  .portal-card__figure {
    margin: 0;
    margin-top: auto;
    flex: 1;
    display: flex;
    align-items: stretch;
    justify-content: stretch;
    border-top: 1px solid var(--c-hairline);
    background: color-mix(in srgb, var(--c-ink) 3%, transparent);
    position: relative;
    overflow: hidden;
    min-height: 240px;
  }
  .portal-card__figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }
</style>
