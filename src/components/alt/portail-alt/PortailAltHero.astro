---
import EyebrowTag from "@/components/alt/shared/EyebrowTag.astro";
import ButtonInButton from "@/components/alt/shared/ButtonInButton.astro";
import FadeUpOnView from "@/components/alt/motion/FadeUpOnView.tsx";
import type { Locale } from "@/i18n/config";

type TitleLine = string | { italic: true; text: string };

interface Cta {
  label: string;
  href: string;
}

interface Props {
  locale: Locale;
  eyebrow: string;
  titleLines: readonly TitleLine[];
  sub: string;
  ctaPrimary: Cta;
  ctaSecondary: Cta;
  proof: readonly string[];
  frames: {
    primaryCaption: string;
    indexCaption: string;
    sheetCaption: string;
  };
}

const { locale, eyebrow, titleLines, sub, ctaPrimary, ctaSecondary, proof, frames } = Astro.props;
const homeImage = `/showcase/portail-alt/home-${locale}.png`;
const indexImage = `/showcase/portail-alt/preview-taxons-${locale}.png`;
const speciesImage = `/showcase/portail-alt/species-${locale}.png`;
const imageLocale = locale === "fr" ? "French" : "English";
---

<section class="portail-alt-hero portail-alt-section" aria-label="Portail alt hero">
  <div class="portail-alt-hero__grid">
    <FadeUpOnView client:visible blur={0} className="portail-alt-hero__copy">
      <EyebrowTag variant="outlined">{eyebrow}</EyebrowTag>

      <h1 class="display portail-alt-hero__title">
        {titleLines.map((line) => {
          if (typeof line === "string") {
            return <span class="portail-alt-hero__line">{line}</span>;
          }
          return (
            <span class="portail-alt-hero__line portail-alt-hero__line--italic">
              <em>{line.text}</em>
            </span>
          );
        })}
      </h1>

      <p class="portail-alt-hero__sub">{sub}</p>

      <ul class="portail-alt-hero__proof">
        {proof.map((item) => (
          <li>{item}</li>
        ))}
      </ul>

      <div class="portail-alt-hero__cta">
        <ButtonInButton variant="primary" href={ctaPrimary.href} target="_blank" rel="noopener">
          {ctaPrimary.label}
        </ButtonInButton>
        <ButtonInButton variant="secondary" href={ctaSecondary.href}>
          {ctaSecondary.label}
        </ButtonInButton>
      </div>
    </FadeUpOnView>

    <FadeUpOnView client:visible delay={0.1} className="portail-alt-hero__stage">
      <article class="portail-alt-frame portail-alt-hero__primary">
        <div class="portail-alt-frame__topline">
          <span class="portail-alt-frame__label">Portal front page</span>
          <span class="portail-alt-frame__meta">orientation before metrics</span>
        </div>
        <img
          class="portail-alt-shot portail-alt-shot--hero portail-alt-shot--home-tight"
          src={homeImage}
          alt={`${imageLocale} preview of the Niamoto portal home page`}
          loading="eager"
          decoding="async"
        />
        <p class="portail-alt-caption">{frames.primaryCaption}</p>
      </article>

      <div class="portail-alt-hero__stack">
        <article class="portail-alt-frame">
          <div class="portail-alt-frame__topline">
            <span class="portail-alt-frame__label">Taxon index</span>
            <span class="portail-alt-frame__meta">corpus view</span>
          </div>
          <div class="portail-alt-shot-viewport portail-alt-shot-viewport--index">
            <img
              class="portail-alt-shot portail-alt-shot--index-fit"
              src={indexImage}
              alt={`${imageLocale} full-width preview of the Niamoto taxon index`}
              loading="lazy"
              decoding="async"
            />
          </div>
          <p class="portail-alt-caption">{frames.indexCaption}</p>
        </article>

        <article class="portail-alt-frame">
          <div class="portail-alt-frame__topline">
            <span class="portail-alt-frame__label">Species sheet</span>
            <span class="portail-alt-frame__meta">reference surface</span>
          </div>
          <img
            class="portail-alt-shot portail-alt-shot--card"
            src={speciesImage}
            alt={`${imageLocale} preview of a Niamoto species page`}
            loading="lazy"
            decoding="async"
          />
          <p class="portail-alt-caption">{frames.sheetCaption}</p>
        </article>
      </div>
    </FadeUpOnView>
  </div>
</section>

<style>
  .portail-alt-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(420px, 0.98fr);
    gap: 2.5rem;
    align-items: start;
  }

  .portail-alt-hero__copy {
    padding-top: 7rem;
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .portail-alt-hero__title {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    font-size: clamp(3.3rem, 9vw, 7.6rem);
    letter-spacing: -0.05em;
    color: var(--c-ink);
  }

  .portail-alt-hero__line {
    display: block;
  }

  .portail-alt-hero__line--italic em {
    font-style: italic;
    color: var(--c-accent);
    font-variation-settings: "wght" 420;
  }

  .portail-alt-hero__sub {
    margin: 0;
    max-width: 40rem;
    color: var(--c-muted);
    font-size: 1.1rem;
  }

  .portail-alt-hero__proof {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.65rem;
    max-width: 34rem;
  }

  .portail-alt-hero__proof li {
    padding-top: 0.7rem;
    border-top: 1px solid var(--c-hairline);
    color: var(--c-ink);
    font-size: 0.96rem;
  }

  .portail-alt-hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 0.2rem;
  }

  .portail-alt-hero__stage {
    display: grid;
    gap: 1.25rem;
  }

  .portail-alt-hero__stack {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  @media (max-width: 980px) {
    .portail-alt-hero__grid {
      grid-template-columns: 1fr;
    }

    .portail-alt-hero__copy {
      padding-top: 5.5rem;
    }
  }

  @media (max-width: 720px) {
    .portail-alt-hero__copy {
      padding-top: 5rem;
    }

    .portail-alt-hero__title {
      font-size: clamp(2.8rem, 14vw, 4.5rem);
    }

    .portail-alt-hero__stack {
      grid-template-columns: 1fr;
    }
  }
</style>
