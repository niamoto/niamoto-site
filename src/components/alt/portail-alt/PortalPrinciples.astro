---
import EyebrowTag from "@/components/alt/shared/EyebrowTag.astro";
import FadeUpOnView from "@/components/alt/motion/FadeUpOnView.tsx";

interface Item {
  title: string;
  body: string;
}

interface Props {
  kicker: string;
  heading: string;
  lead: string;
  items: readonly Item[];
}

const { kicker, heading, lead, items } = Astro.props;
---

<section class="portail-alt-section" aria-labelledby="portail-alt-principles-heading">
  <div class="portail-alt-principles">
    <FadeUpOnView client:visible className="portail-alt-principles__lead">
      <EyebrowTag variant="accent">{kicker}</EyebrowTag>
      <h2 id="portail-alt-principles-heading" class="display portail-alt-heading">{heading}</h2>
      <p class="portail-alt-principles__leadcopy">{lead}</p>
    </FadeUpOnView>

    <div class="portail-alt-principles__grid">
      {items.map((item, index) => (
        <FadeUpOnView client:visible delay={0.05 + index * 0.05} className="portail-alt-principles__item">
          <h3 class="display portail-alt-principles__title">{item.title}</h3>
          <p class="portail-alt-principles__body">{item.body}</p>
        </FadeUpOnView>
      ))}
    </div>
  </div>
</section>

<style>
  .portail-alt-principles {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
    gap: 2rem;
    align-items: start;
  }

  .portail-alt-principles__lead {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-right: 1rem;
  }

  .portail-alt-principles__leadcopy {
    margin: 0;
    max-width: 34rem;
    color: var(--c-muted);
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .portail-alt-principles__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .portail-alt-principles__item {
    padding-top: 1.1rem;
    border-top: 1px solid var(--c-hairline);
  }

  .portail-alt-principles__title {
    font-size: clamp(1.25rem, 2vw, 1.65rem);
    color: var(--c-ink);
    letter-spacing: -0.025em;
  }

  .portail-alt-principles__body {
    margin: 0.65rem 0 0;
    color: var(--c-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 980px) {
    .portail-alt-principles {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .portail-alt-principles__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
