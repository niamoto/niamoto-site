---
import AltLayout from "@/layouts/AltLayout.astro";
import IslandNav from "@/components/alt/shared/IslandNav.astro";
import type { Locale } from "@/i18n/config";
import enCopy from "@/i18n/alt/frond.en";
import frCopy from "@/i18n/alt/frond.fr";

import FrondHero from "./FrondHero.astro";
import FrondWidgetBand from "./FrondWidgetBand.astro";
import FrondPillars from "./FrondPillars.astro";
import FrondReading from "./FrondReading.astro";
import FrondSequence from "./FrondSequence.astro";
import FrondShowcase from "./FrondShowcase.astro";
import FrondTwoWays from "./FrondTwoWays.astro";
import FrondPrinciples from "./FrondPrinciples.astro";
import FrondClosing from "./FrondClosing.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = locale === "fr" ? frCopy : enCopy;
---

<AltLayout
  theme="frond"
  locale={locale}
  title={t.meta.title}
  description={t.meta.description}
  slug="frond"
>
  <a href="#main" class="skip-link">Skip to content</a>
  <IslandNav locale={locale} slug="frond" />

  <main id="main" class="frond-shell">
    <FrondHero {...t.hero} />
    <FrondWidgetBand {...t.widgetBand} />
    <FrondPillars {...t.pillars} />
    <FrondReading locale={locale} {...t.reading} />
    <FrondSequence {...t.sequence} />
    <FrondShowcase locale={locale} {...t.showcase} />
    <FrondTwoWays {...t.twoWays} />
    <FrondPrinciples {...t.principles} />
    <FrondClosing
      eyebrow={t.closing.eyebrow}
      title={t.closing.title}
      body={t.closing.body}
      ctaPrimary={t.closing.ctaPrimary}
      ctaSecondary={t.closing.ctaSecondary}
      license={t.closing.license}
      fundersHeading={t.funders.heading}
    />
  </main>
</AltLayout>
