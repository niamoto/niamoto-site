---
import ButtonInButton from "@/components/alt/shared/ButtonInButton.astro";
import FunderGrid from "@/components/alt/shared/FunderGrid.astro";
import FadeUpOnView from "@/components/alt/motion/FadeUpOnView.tsx";

interface Props {
  title: string;
  body: string;
  ctaPrimary: string;
  ctaSecondary: string;
  fundersHeading: string;
}

const { title, body, ctaPrimary, ctaSecondary, fundersHeading } = Astro.props;
---

<section class="strate-closing" aria-label={title}>
  <FadeUpOnView client:visible className="strate-closing__inner">
    <hr class="strate-closing__rule" />
    <h2 class="display strate-closing__title">{title}</h2>
    <p class="strate-closing__body">{body}</p>
    <div class="strate-closing__cta">
      <ButtonInButton variant="primary" href="https://github.com/niamoto/niamoto" target="_blank" rel="noopener">
        {ctaPrimary}
      </ButtonInButton>
      <ButtonInButton variant="secondary" href="/documentation">
        {ctaSecondary}
      </ButtonInButton>
    </div>
  </FadeUpOnView>

  <FadeUpOnView client:visible delay={0.15} className="strate-closing__funders">
    <FunderGrid heading={fundersHeading} variant="compact" />
  </FadeUpOnView>
</section>

<style>
  .strate-closing {
    padding: 3rem 1.5rem 6rem;
    max-width: 1180px;
    margin: 0 auto;
  }
  .strate-closing__inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 52rem;
    margin-bottom: 4rem;
  }
  .strate-closing__rule {
    border: none;
    border-top: 1px solid var(--c-hairline);
    margin: 2rem 0 1.5rem;
    width: 80px;
  }
  .strate-closing__title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-variation-settings: "opsz" 90, "wght" 500, "WONK" 0, "SOFT" 75;
    color: var(--c-ink);
    letter-spacing: -0.028em;
    margin: 0;
  }
  .strate-closing__body {
    margin: 0;
    color: var(--c-muted);
    font-size: 1rem;
    line-height: 1.7;
  }
  .strate-closing__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }
  .strate-closing__funders {
    padding-top: 3rem;
    border-top: 1px solid var(--c-hairline);
  }
</style>
