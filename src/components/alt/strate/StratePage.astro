---
import AltLayout from "@/layouts/AltLayout.astro";
import IslandNav from "@/components/alt/shared/IslandNav.astro";
import HeroStrate from "./HeroStrate.astro";
import NumberedSection from "./NumberedSection.astro";
import StrateClosing from "./StrateClosing.astro";
import type { Locale } from "@/i18n/config";
import enCopy from "@/i18n/alt/strate.en";
import frCopy from "@/i18n/alt/strate.fr";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = locale === "fr" ? frCopy : enCopy;

// Narrow chapter types for the component -- Astro's type inference from `as const`
// would make readonly fields, but NumberedSection expects plain shapes.
const chapters = t.chapters;
---

<AltLayout
  theme="strate"
  locale={locale}
  title={t.meta.title}
  description={t.meta.description}
  slug="strate"
>
  <a href="#main" class="skip-link">Skip to content</a>
  <IslandNav locale={locale} slug="strate" />

  <main id="main">
    <HeroStrate
      eyebrow={t.hero.eyebrow}
      titleLines={t.hero.titleLines}
      sub={t.hero.sub}
      ctaPrimary={t.hero.cta}
      ctaSecondary={t.hero.ctaSecondary}
      byline={t.hero.byline}
    />

    <article class="strate-body">
      {chapters.map((ch) => (
        <NumberedSection
          num={ch.num}
          label={ch.label}
          title={ch.title}
          body={ch.body}
          pull={"pull" in ch ? ch.pull : undefined}
          stat={"stat" in ch ? ch.stat : undefined}
          snippet={"snippet" in ch ? ch.snippet : undefined}
          figureCaption={"figureCaption" in ch ? ch.figureCaption : undefined}
          locale={locale}
        />
      ))}
    </article>

    <StrateClosing
      title={t.closing.title}
      body={t.closing.body}
      ctaPrimary={t.closing.ctaPrimary}
      ctaSecondary={t.closing.ctaSecondary}
      fundersHeading={t.funders.heading}
    />
  </main>
</AltLayout>

<style>
  .strate-body {
    padding: 2rem 0 2rem;
  }
</style>
