---
import EyebrowTag from "@/components/alt/shared/EyebrowTag.astro";
import ButtonInButton from "@/components/alt/shared/ButtonInButton.astro";
import FadeUpOnView from "@/components/alt/motion/FadeUpOnView.tsx";

type TitleLine = string | { italic: true; text: string };

interface Props {
  eyebrow: string;
  titleLines: readonly TitleLine[];
  sub: string;
  ctaPrimary: string;
  ctaSecondary: string;
  byline: string;
}

const { eyebrow, titleLines, sub, ctaPrimary, ctaSecondary, byline } = Astro.props;
---

<section class="strate-hero" aria-label="Hero">
  <FadeUpOnView client:visible blur={0} className="strate-hero__inner">
    <EyebrowTag variant="outlined">{eyebrow}</EyebrowTag>

    <h1 class="display strate-headline">
      {titleLines.map((line) => {
        if (typeof line === "string") {
          return <span class="strate-headline__line">{line}</span>;
        }
        return <span class="strate-headline__line"><em>{line.text}</em></span>;
      })}
    </h1>

    <p class="strate-hero__sub">{sub}</p>

    <p class="strate-hero__byline alt-mono">{byline}</p>

    <div class="strate-hero__cta">
      <ButtonInButton variant="primary" href="https://github.com/niamoto/niamoto">
        {ctaPrimary}
      </ButtonInButton>
      <ButtonInButton variant="secondary" href="#ch-01">
        {ctaSecondary}
      </ButtonInButton>
    </div>
  </FadeUpOnView>
</section>

<style>
  .strate-hero {
    padding: 10rem 1.5rem 4rem;
    max-width: 1180px;
    margin: 0 auto;
  }
  .strate-hero__inner {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    max-width: 52rem;
  }
  .strate-headline {
    display: flex;
    flex-direction: column;
    font-size: clamp(2.8rem, 7.5vw, 6rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-variation-settings: "opsz" 144, "wght" 400, "WONK" 0, "SOFT" 50;
    color: var(--c-ink);
  }
  .strate-headline__line {
    display: block;
  }
  .strate-hero__sub {
    max-width: 44rem;
    color: var(--c-muted);
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    line-height: 1.65;
    margin: 0;
  }
  .strate-hero__byline {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--c-muted);
    text-transform: uppercase;
    margin: 0;
  }
  .strate-hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  @media (max-width: 768px) {
    .strate-hero {
      padding: 7rem 1rem 3rem;
    }
  }
</style>
