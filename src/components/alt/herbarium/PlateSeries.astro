---
import StaggeredReveal from "@/components/alt/motion/StaggeredReveal.tsx";

interface Plate {
  genus: string;
  species: string;
  family: string;
  note: string;
  collection: string;
}

interface Props {
  heading: string;
  intro: string;
  items: readonly Plate[];
}

const { heading, intro, items } = Astro.props;
---

<section class="herb-series" id="series">
  <div class="herb-series__inner">
    <header class="herb-series__head">
      <h2 class="display herb-series__heading">{heading}</h2>
      <p class="herb-series__intro">{intro}</p>
    </header>

    <StaggeredReveal client:visible stagger={0.1} y={20} as="div" className="herb-series__grid">
      {items.map((p) => (
        <article class="herb-plate">
          <div class="herb-plate__art" aria-hidden="true">
            <svg viewBox="0 0 200 280" xmlns="http://www.w3.org/2000/svg" class="specimen-photo" preserveAspectRatio="xMidYMid slice">
              <rect width="200" height="280" fill="rgba(232, 220, 200, 0.04)" />
              <g stroke="rgba(232, 220, 200, 0.4)" stroke-width="1" fill="none" stroke-linecap="round">
                <path d="M100 30 L 100 250" />
                <path d="M100 60 Q 75 80, 60 110" /><path d="M100 60 Q 125 80, 140 110" />
                <path d="M100 110 Q 70 130, 50 160" /><path d="M100 110 Q 130 130, 150 160" />
                <path d="M100 160 Q 78 180, 65 210" /><path d="M100 160 Q 122 180, 135 210" />
              </g>
              <g fill="rgba(232, 220, 200, 0.14)">
                <ellipse cx="60" cy="110" rx="12" ry="5" transform="rotate(-30 60 110)" />
                <ellipse cx="140" cy="110" rx="12" ry="5" transform="rotate(30 140 110)" />
                <ellipse cx="50" cy="160" rx="14" ry="6" transform="rotate(-25 50 160)" />
                <ellipse cx="150" cy="160" rx="14" ry="6" transform="rotate(25 150 160)" />
                <ellipse cx="65" cy="210" rx="13" ry="6" transform="rotate(-20 65 210)" />
                <ellipse cx="135" cy="210" rx="13" ry="6" transform="rotate(20 135 210)" />
              </g>
            </svg>
          </div>
          <div class="herb-plate__caption">
            <span class="specimen-caption">{p.family}</span>
            <h3 class="herb-plate__name"><em>{p.genus}</em>{" "}<em>{p.species}</em></h3>
            <p class="herb-plate__note">{p.note}</p>
            <span class="herb-plate__collection">{p.collection}</span>
          </div>
        </article>
      ))}
    </StaggeredReveal>
  </div>
</section>

<style>
  .herb-series {
    width: 100%;
    padding: 5rem 1.5rem;
    border-top: 1px solid var(--c-hairline);
  }
  .herb-series__inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .herb-series__head {
    margin-bottom: 3rem;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    align-items: end;
  }
  .herb-series__heading {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--c-ink);
    max-width: 16ch;
  }
  .herb-series__intro {
    margin: 0;
    color: var(--c-muted);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 50ch;
  }
  .herb-series__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.5rem;
  }
  .herb-plate {
    background: var(--c-surface);
    border: 1px solid var(--c-hairline);
    border-radius: 0.5rem;
    overflow: hidden;
    transition: transform 320ms cubic-bezier(0.32, 0.72, 0, 1),
                border-color 320ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .herb-plate:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--c-accent) 50%, var(--c-hairline));
  }
  .herb-plate__art {
    width: 100%;
    aspect-ratio: 5 / 7;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .herb-plate__art svg { width: 100%; height: 100%; }
  .herb-plate__caption {
    padding: 1rem 1.1rem 1.25rem;
    border-top: 1px solid var(--c-hairline);
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .herb-plate__name {
    margin: 0;
    font-family: var(--f-display);
    font-variation-settings: "opsz" 144, "wght" 600, "WONK" 0, "SOFT" 50;
    font-size: 1.05rem;
    color: var(--c-ink);
    letter-spacing: -0.02em;
  }
  .herb-plate__name em { font-style: italic; }
  .herb-plate__note {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--c-muted);
  }
  .herb-plate__collection {
    font-family: var(--f-mono);
    font-size: 0.7rem;
    color: var(--c-accent);
    letter-spacing: 0.06em;
  }

  @media (max-width: 1024px) {
    .herb-series__head {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .herb-series__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 560px) {
    .herb-series__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
