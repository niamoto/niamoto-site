---
import DoubleBezel from "@/components/alt/shared/DoubleBezel.astro";

interface Props {
  /** Latin name in italic display. */
  name: string;
  /** Family + region, mono small caps. */
  family: string;
  /** Collection number. */
  collection: string;
  /** Visual size variant. */
  size?: "lg" | "md";
}

const { name, family, collection, size = "md" } = Astro.props;
---

<DoubleBezel outerRadius="0.5rem" outerPad="0.5rem" class="herb-specimen" innerClass="herb-specimen__inner">
  <div class={`herb-specimen__art herb-specimen__art--${size}`}>
    <svg viewBox="0 0 320 440" xmlns="http://www.w3.org/2000/svg" class="specimen-photo" preserveAspectRatio="xMidYMid slice">
      <defs>
        <radialGradient id="herb-glow" cx="50%" cy="40%">
          <stop offset="0%" stop-color="rgba(184, 124, 79, 0.18)" />
          <stop offset="70%" stop-color="rgba(184, 124, 79, 0.02)" />
          <stop offset="100%" stop-color="rgba(0,0,0,0)" />
        </radialGradient>
      </defs>

      <rect width="320" height="440" fill="rgba(122, 139, 111, 0.05)" />
      <rect width="320" height="440" fill="url(#herb-glow)" />

      <g stroke="rgba(232, 220, 200, 0.55)" stroke-width="1.1" fill="none" stroke-linecap="round">
        <path d="M160 30 L 160 410" />
        <path d="M160 60 Q 130 70, 100 95" /><path d="M160 60 Q 190 70, 220 95" />
        <path d="M160 100 Q 110 130, 70 170" /><path d="M160 100 Q 210 130, 250 170" />
        <path d="M160 150 Q 120 180, 90 230" /><path d="M160 150 Q 200 180, 230 230" />
        <path d="M160 200 Q 130 230, 110 280" /><path d="M160 200 Q 190 230, 210 280" />
        <path d="M160 250 Q 140 280, 130 330" /><path d="M160 250 Q 180 280, 190 330" />
      </g>

      <g fill="rgba(232, 220, 200, 0.18)">
        <ellipse cx="100" cy="95" rx="14" ry="6" transform="rotate(-30 100 95)" />
        <ellipse cx="220" cy="95" rx="14" ry="6" transform="rotate(30 220 95)" />
        <ellipse cx="70" cy="170" rx="18" ry="8" transform="rotate(-25 70 170)" />
        <ellipse cx="250" cy="170" rx="18" ry="8" transform="rotate(25 250 170)" />
        <ellipse cx="90" cy="230" rx="20" ry="9" transform="rotate(-22 90 230)" />
        <ellipse cx="230" cy="230" rx="20" ry="9" transform="rotate(22 230 230)" />
        <ellipse cx="110" cy="280" rx="16" ry="7" transform="rotate(-18 110 280)" />
        <ellipse cx="210" cy="280" rx="16" ry="7" transform="rotate(18 210 280)" />
      </g>
    </svg>
  </div>

  <div class="herb-specimen__caption">
    <span class="specimen-caption">{family}</span>
    <h3 class="herb-specimen__name">
      <em>{name}</em>
    </h3>
    <span class="specimen-caption herb-specimen__collection">{collection}</span>
  </div>
</DoubleBezel>

<style>
  :global(.herb-specimen) {
    width: 100%;
    background: color-mix(in srgb, var(--c-canvas) 90%, var(--c-accent) 10%);
  }
  :global(.herb-specimen__inner) {
    background: var(--c-canvas);
    overflow: hidden;
  }
  .herb-specimen__art {
    width: 100%;
    background: rgba(232, 220, 200, 0.02);
  }
  .herb-specimen__art--lg { aspect-ratio: 4 / 5; }
  .herb-specimen__art--md { aspect-ratio: 4 / 5; }
  .herb-specimen__art svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .herb-specimen__caption {
    padding: 1.25rem 1.5rem 1.5rem;
    border-top: 1px solid var(--c-hairline);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .herb-specimen__name {
    font-family: var(--f-display);
    font-variation-settings: "opsz" 144, "wght" 700, "WONK" 0, "SOFT" 50;
    font-size: 1.6rem;
    color: var(--c-ink);
    letter-spacing: -0.03em;
    margin: 0;
  }
  .herb-specimen__name em {
    font-style: italic;
  }
  .herb-specimen__collection {
    color: var(--c-accent);
  }
</style>
