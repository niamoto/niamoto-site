---
import EyebrowTag from "@/components/alt/shared/EyebrowTag.astro";
import ButtonInButton from "@/components/alt/shared/ButtonInButton.astro";
import FadeUpOnView from "@/components/alt/motion/FadeUpOnView.tsx";
import SpecimenFrame from "./SpecimenFrame.astro";

interface Props {
  eyebrow: string;
  titleLine1: string;
  titleLine2: string;
  titleLine3: string;
  sub: string;
  cta: string;
  ctaSecondary: string;
  specimenName: string;
  specimenFamily: string;
  specimenCollection: string;
}

const {
  eyebrow,
  titleLine1,
  titleLine2,
  titleLine3,
  sub,
  cta,
  ctaSecondary,
  specimenName,
  specimenFamily,
  specimenCollection,
} = Astro.props;
---

<section class="herb-hero">
  <div class="herb-hero__inner">
    <FadeUpOnView client:visible className="herb-hero__copy">
      <EyebrowTag variant="accent" class="herb-hero__eyebrow">{eyebrow}</EyebrowTag>
      <h1 class="display herb-hero__title">
        <span class="herb-hero__line">{titleLine1}</span>
        <br />
        <span class="herb-hero__line">{titleLine2}</span>
        <br />
        <span class="herb-hero__line herb-hero__line--accent"><em>{titleLine3}</em></span>
      </h1>
      <p class="herb-hero__sub">{sub}</p>
      <div class="herb-hero__cta">
        <ButtonInButton variant="primary" href="#install">{cta}</ButtonInButton>
        <ButtonInButton variant="secondary" href="#series">{ctaSecondary}</ButtonInButton>
      </div>
    </FadeUpOnView>

    <FadeUpOnView client:visible delay={0.18} className="herb-hero__frame">
      <SpecimenFrame
        name={specimenName}
        family={specimenFamily}
        collection={specimenCollection}
        size="lg"
      />
    </FadeUpOnView>
  </div>
</section>

<style>
  .herb-hero {
    width: 100%;
    padding: 8rem 1.5rem 5rem;
  }
  .herb-hero__inner {
    max-width: 1320px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .herb-hero__eyebrow {
    margin-bottom: 1.75rem;
  }
  .herb-hero__title {
    font-size: clamp(3rem, 8vw, 7rem);
    color: var(--c-ink);
  }
  .herb-hero__line {
    display: block;
  }
  .herb-hero__line--accent em {
    font-style: italic;
    color: var(--c-accent);
  }
  .herb-hero__sub {
    margin-top: 2rem;
    max-width: 36ch;
    color: var(--c-muted);
    font-size: 1.05rem;
    line-height: 1.65;
  }
  .herb-hero__cta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }
  .herb-hero__frame {
    max-width: 460px;
    margin-left: auto;
  }
  @media (max-width: 1024px) {
    .herb-hero__inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .herb-hero__frame {
      max-width: 360px;
      margin: 0 auto;
    }
  }
</style>
