---
import AltLayout from "@/layouts/AltLayout.astro";
import IslandNav from "@/components/alt/shared/IslandNav.astro";
import ButtonInButton from "@/components/alt/shared/ButtonInButton.astro";
import FunderGrid from "@/components/alt/shared/FunderGrid.astro";
import StaggeredReveal from "@/components/alt/motion/StaggeredReveal.tsx";
import FadeUpOnView from "@/components/alt/motion/FadeUpOnView.tsx";
import HeroSplit from "./HeroSplit.astro";
import PlateSeries from "./PlateSeries.astro";
import type { Locale } from "@/i18n/config";
import enCopy from "@/i18n/alt/herbarium.en";
import frCopy from "@/i18n/alt/herbarium.fr";

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = locale === "fr" ? frCopy : enCopy;
---

<AltLayout
  theme="herbarium"
  locale={locale}
  title={t.meta.title}
  description={t.meta.description}
  slug="herbarium"
>
  <a href="#main" class="skip-link">Skip to content</a>
  <IslandNav locale={locale} slug="herbarium" />

  <main id="main">
    <HeroSplit
      eyebrow={t.hero.eyebrow}
      titleLine1={t.hero.titleLine1}
      titleLine2={t.hero.titleLine2}
      titleLine3={t.hero.titleLine3}
      sub={t.hero.sub}
      cta={t.hero.cta}
      ctaSecondary={t.hero.ctaSecondary}
      specimenName={t.hero.specimenName}
      specimenFamily={t.hero.specimenFamily}
      specimenCollection={t.hero.specimenCollection}
    />

    <section class="herb-scope">
      <div class="herb-scope__inner">
        <h2 class="display herb-scope__heading">{t.scope.heading}</h2>
        <StaggeredReveal client:visible stagger={0.12} y={18} as="ul" className="herb-scope__list">
          {t.scope.items.map((s) => (
            <li class="herb-scope__row">
              <span class="herb-scope__kicker">{s.kicker}</span>
              <span class="herb-scope__value stat-number">{s.value}</span>
              <span class="herb-scope__body">{s.body}</span>
            </li>
          ))}
        </StaggeredReveal>
      </div>
    </section>

    <PlateSeries heading={t.series.heading} intro={t.series.intro} items={t.series.items} />

    <section class="herb-closing">
      <div class="herb-closing__inner">
        <FadeUpOnView client:visible>
          <h2 class="display herb-closing__title">{t.closing.title}</h2>
          <p class="herb-closing__body">{t.closing.body}</p>
          <div class="herb-closing__cta">
            <ButtonInButton variant="primary" href="https://github.com/niamoto/niamoto" target="_blank" rel="noopener">
              {t.closing.ctaPrimary}
            </ButtonInButton>
            <ButtonInButton variant="secondary" href="/documentation">
              {t.closing.ctaSecondary}
            </ButtonInButton>
          </div>
        </FadeUpOnView>

        <FadeUpOnView client:visible delay={0.1} className="herb-closing__funders">
          <FunderGrid heading={t.funders.heading} />
        </FadeUpOnView>
      </div>
    </section>
  </main>
</AltLayout>

<style>
  .herb-scope {
    width: 100%;
    padding: 5rem 1.5rem;
    border-top: 1px solid var(--c-hairline);
  }
  .herb-scope__inner {
    max-width: 1080px;
    margin: 0 auto;
  }
  .herb-scope__heading {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    color: var(--c-ink);
    margin-bottom: 2.5rem;
    max-width: 22ch;
  }
  .herb-scope__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--c-hairline);
  }
  .herb-scope__row {
    display: grid;
    grid-template-columns: 130px auto 1fr;
    gap: 2rem;
    align-items: baseline;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--c-hairline);
  }
  .herb-scope__kicker {
    font-family: var(--f-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--c-accent);
  }
  .herb-scope__value {
    font-family: var(--f-display);
    font-variation-settings: "opsz" 144, "wght" 800, "WONK" 0, "SOFT" 50;
    font-size: 2.5rem;
    color: var(--c-ink);
    letter-spacing: -0.04em;
    line-height: 1;
  }
  .herb-scope__body {
    color: var(--c-muted);
    font-size: 0.95rem;
    line-height: 1.55;
    max-width: 40ch;
  }
  .herb-closing {
    padding: 5rem 1.5rem;
    border-top: 1px solid var(--c-hairline);
  }
  .herb-closing__inner {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }
  .herb-closing__title {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--c-ink);
    max-width: 22ch;
  }
  .herb-closing__body {
    margin-top: 1rem;
    max-width: 50ch;
    color: var(--c-muted);
    font-size: 1rem;
  }
  .herb-closing__cta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }
  .herb-closing__funders {
    width: 100%;
    border-top: 1px solid var(--c-hairline);
    padding-top: 2.5rem;
  }
  @media (max-width: 720px) {
    .herb-scope__row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
