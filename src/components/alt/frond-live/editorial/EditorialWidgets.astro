---
/*
 * EditorialWidgets — faithful port of the app's Collections > Blocks editor.
 * Source of truth: src/niamoto/gui/ui/src/features/collections/components/CollectionPanel.tsx
 * Two-pane layout: configured widgets list (left) + live preview (right).
 * Real widget names from nouvelle-caledonie taxons config.
 */

import MacWindow from "./MacWindow.astro";
---

<MacWindow title="Niamoto" subtitle="Collections · taxons · Blocks">
  <div class="edw">
    <!-- Toolbar -->
    <div class="edw__toolbar">
      <span class="edw__badge">18 widgets configured</span>
      <span class="edw__entities">1 667 entities · Hierarchical</span>
      <span class="edw__save">
        <svg viewBox="0 0 24 24" width="7" height="7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        Save
      </span>
    </div>

    <div class="edw__panes">
      <!-- Left pane: configured widget list -->
      <div class="edw__list">
        <div class="edw__add">
          <svg viewBox="0 0 24 24" width="8" height="8" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          <span>Add widget</span>
        </div>

        <div class="edw__item">
          <span class="edw__drag" aria-hidden="true">⋮⋮</span>
          <span class="edw__name">Navigation taxonomique</span>
          <span class="edw__kind edw__kind--nav">Nav</span>
        </div>
        <div class="edw__item">
          <span class="edw__drag" aria-hidden="true">⋮⋮</span>
          <span class="edw__name">Distribution géographique</span>
          <span class="edw__kind edw__kind--map">Map</span>
        </div>
        <div class="edw__item">
          <span class="edw__drag" aria-hidden="true">⋮⋮</span>
          <span class="edw__name">Informations générales</span>
          <span class="edw__kind edw__kind--info">Info</span>
        </div>
        <div class="edw__item">
          <span class="edw__drag" aria-hidden="true">⋮⋮</span>
          <span class="edw__name">Sous-taxons principaux</span>
          <span class="edw__kind edw__kind--chart">Bar</span>
        </div>
        <div class="edw__item">
          <span class="edw__drag" aria-hidden="true">⋮⋮</span>
          <span class="edw__name">Distribution DBH</span>
          <span class="edw__kind edw__kind--chart">Bar</span>
        </div>
        <div class="edw__item">
          <span class="edw__drag" aria-hidden="true">⋮⋮</span>
          <span class="edw__name">Hauteur maximale</span>
          <span class="edw__kind edw__kind--gauge">Gauge</span>
        </div>
        <div class="edw__more">+ 12 more</div>
      </div>

      <!-- Right pane: live preview stack -->
      <div class="edw__preview">
        <div class="edw__widget">
          <div class="edw__widget-head">
            <span class="edw__widget-title">Distribution géographique</span>
            <span class="edw__kind edw__kind--map">Map</span>
          </div>
          <svg viewBox="0 0 100 30" class="edw__map" aria-hidden="true">
            <!-- Stylised NC shape -->
            <path d="M10,18 Q22,10 35,16 T60,14 Q78,20 90,17 L92,22 Q82,27 65,23 T38,25 Q22,22 10,24 Z"
                  fill="#f3efe4" stroke="#c4b393" stroke-width="0.4" stroke-linejoin="round"/>
            <!-- occurrence dots -->
            <circle cx="22" cy="20" r="0.8" fill="#7e22ce"/>
            <circle cx="28" cy="18" r="0.9" fill="#7e22ce"/>
            <circle cx="34" cy="19" r="0.7" fill="#7e22ce"/>
            <circle cx="40" cy="17" r="1.1" fill="#7e22ce"/>
            <circle cx="46" cy="19" r="0.8" fill="#7e22ce"/>
            <circle cx="52" cy="18" r="0.9" fill="#7e22ce"/>
            <circle cx="58" cy="20" r="0.7" fill="#7e22ce"/>
            <circle cx="64" cy="19" r="0.8" fill="#7e22ce"/>
            <circle cx="70" cy="20" r="0.9" fill="#7e22ce"/>
            <circle cx="76" cy="21" r="0.7" fill="#7e22ce"/>
            <circle cx="82" cy="20" r="0.8" fill="#7e22ce"/>
          </svg>
        </div>

        <div class="edw__widget-row">
          <div class="edw__widget edw__widget--half">
            <div class="edw__widget-head">
              <span class="edw__widget-title">Sous-taxons principaux</span>
            </div>
            <div class="edw__bars">
              <div class="edw__bar"><span class="edw__bar-label">Tristaniopsis</span><span class="edw__bar-fill" style="width:96%; background:#60a5fa"></span></div>
              <div class="edw__bar"><span class="edw__bar-label">Melaleuca</span><span class="edw__bar-fill" style="width:84%; background:#ef4444"></span></div>
              <div class="edw__bar"><span class="edw__bar-label">Arillastrum</span><span class="edw__bar-fill" style="width:78%; background:#22c55e"></span></div>
              <div class="edw__bar"><span class="edw__bar-label">Syzygium</span><span class="edw__bar-fill" style="width:62%; background:#a855f7"></span></div>
            </div>
          </div>

          <div class="edw__widget edw__widget--half">
            <div class="edw__widget-head">
              <span class="edw__widget-title">Hauteur maximale</span>
            </div>
            <svg viewBox="0 0 60 32" class="edw__gauge" aria-hidden="true">
              <path d="M8,28 A22,22 0 0 1 52,28" fill="none" stroke="#f3f4f6" stroke-width="5" stroke-linecap="round"/>
              <path d="M8,28 A22,22 0 0 1 43,11" fill="none" stroke="#0d9488" stroke-width="5" stroke-linecap="round"/>
              <text x="30" y="29" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" font-weight="700" fill="#0f172a">45m</text>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</MacWindow>

<style>
  .edw {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 0.35rem 0.45rem;
    gap: 0.3rem;
    font-family: "Plus Jakarta Sans", system-ui, -apple-system, sans-serif;
    color: #111827;
    min-height: 0;
  }

  .edw__toolbar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding-bottom: 0.2rem;
    border-bottom: 1px solid #f1f5f9;
  }

  .edw__badge {
    font-size: 0.5rem;
    font-weight: 600;
    color: #111827;
  }

  .edw__entities {
    flex: 1;
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.45rem;
    color: #9ca3af;
  }

  .edw__save {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.15rem 0.4rem;
    background: #d1fae5;
    color: #047857;
    border-radius: 3px;
    font-size: 0.48rem;
    font-weight: 600;
  }

  /* Two panes */
  .edw__panes {
    flex: 1;
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    gap: 0.3rem;
    min-height: 0;
  }

  /* Left pane — configured widgets list */
  .edw__list {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.25rem;
    background: #f9fafb;
    border: 1px solid #f1f5f9;
    border-radius: 5px;
    min-height: 0;
  }

  .edw__add {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: 0.25rem 0.4rem;
    background: #2e7d32;
    color: #fff;
    border-radius: 4px;
    font-size: 0.5rem;
    font-weight: 600;
    margin-bottom: 0.15rem;
  }

  .edw__item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.2rem 0.3rem;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 3px;
  }

  .edw__drag {
    font-size: 0.4rem;
    color: #cbd5e1;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -1px;
    flex-shrink: 0;
  }

  .edw__name {
    flex: 1;
    font-size: 0.44rem;
    color: #111827;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .edw__kind {
    flex-shrink: 0;
    padding: 0.04rem 0.25rem;
    border-radius: 2px;
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.38rem;
    font-weight: 600;
  }

  .edw__kind--nav   { background: #ede9fe; color: #6d28d9; }
  .edw__kind--map   { background: #d1fae5; color: #047857; }
  .edw__kind--info  { background: #dbeafe; color: #1d4ed8; }
  .edw__kind--chart { background: #fef3c7; color: #b45309; }
  .edw__kind--gauge { background: #ccfbf1; color: #0f766e; }
  .edw__kind--donut { background: #ffedd5; color: #c2410c; }

  .edw__more {
    padding: 0.15rem 0.3rem;
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.4rem;
    color: #9ca3af;
    text-align: center;
  }

  /* Right pane — live preview stack */
  .edw__preview {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-height: 0;
  }

  .edw__widget {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 5px;
    padding: 0.3rem 0.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-height: 0;
  }

  .edw__widget-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.25rem;
  }

  .edw__widget--half {
    min-width: 0;
  }

  .edw__widget-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.3rem;
  }

  .edw__widget-title {
    font-size: 0.45rem;
    font-weight: 600;
    color: #111827;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .edw__map {
    width: 100%;
    height: auto;
    background: #f0f2f6;
    border-radius: 3px;
  }

  .edw__bars {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .edw__bar {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 0.3rem;
    align-items: center;
  }

  .edw__bar-label {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.38rem;
    color: #6b7280;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .edw__bar-fill {
    display: inline-block;
    height: 0.3rem;
    border-radius: 1px;
  }

  .edw__gauge {
    width: 100%;
    height: auto;
    flex: 1;
  }
</style>
