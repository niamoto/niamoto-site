---
/*
 * EditorialImport — faithful port of the app's FileUploadZone, scaled for hero.
 * Source of truth: src/niamoto/gui/ui/src/features/import/components/upload/FileUploadZone.tsx
 * Real file categories (CSV / Vector / Raster), real analysis status states.
 */

import MacWindow from "./MacWindow.astro";
---

<MacWindow title="Niamoto" subtitle="Import sources">
  <div class="edi">
    <!-- Drop zone (compact) -->
    <div class="edi__drop">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#2e7d32" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
        <polyline points="17 8 12 3 7 8" />
        <line x1="12" y1="3" x2="12" y2="15" />
      </svg>
      <div class="edi__drop-title">Drop files here</div>
      <div class="edi__drop-sub">csv · gpkg · geojson · tif · zip</div>
    </div>

    <!-- Grouped files list -->
    <div class="edi__groups">

      <!-- CSV group -->
      <div class="edi__group">
        <div class="edi__group-head">
          <svg viewBox="0 0 24 24" width="8" height="8" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/></svg>
          <span>CSV</span>
        </div>
        <div class="edi__file">
          <span class="edi__name">occurrences.csv</span>
          <span class="edi__status edi__status--done">
            <svg viewBox="0 0 24 24" width="8" height="8" fill="none" stroke="#16a34a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Ready
          </span>
        </div>
        <div class="edi__file">
          <span class="edi__name">plot.csv</span>
          <span class="edi__status edi__status--done">
            <svg viewBox="0 0 24 24" width="8" height="8" fill="none" stroke="#16a34a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Ready
          </span>
        </div>
      </div>

      <!-- Vector group -->
      <div class="edi__group">
        <div class="edi__group-head">
          <svg viewBox="0 0 24 24" width="8" height="8" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
          <span>Vector</span>
        </div>
        <div class="edi__file">
          <span class="edi__name">plots.gpkg</span>
          <span class="edi__status edi__status--detected">
            <svg viewBox="0 0 24 24" width="8" height="8" fill="#3b82f6" stroke="none" aria-hidden="true"><path d="M12 2l2.09 6.43h6.75l-5.46 3.97 2.09 6.43L12 14.86l-5.47 3.97 2.09-6.43L3.16 8.43h6.75z"/></svg>
            Detected
          </span>
        </div>
        <div class="edi__file">
          <span class="edi__name">shapes/provinces.geojson</span>
          <span class="edi__status edi__status--done">
            <svg viewBox="0 0 24 24" width="8" height="8" fill="none" stroke="#16a34a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Ready
          </span>
        </div>
      </div>

      <!-- Raster group -->
      <div class="edi__group">
        <div class="edi__group-head">
          <svg viewBox="0 0 24 24" width="8" height="8" fill="none" stroke="#a855f7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <span>Raster</span>
        </div>
        <div class="edi__file">
          <span class="edi__name">forest-cover.tif</span>
          <span class="edi__status edi__status--analyzing">
            <span class="edi__spinner" aria-hidden="true"></span>
            Analyzing
          </span>
        </div>
      </div>

    </div>
  </div>
</MacWindow>

<style>
  .edi {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 0.55rem 0.7rem;
    gap: 0.4rem;
    font-family: "Plus Jakarta Sans", system-ui, -apple-system, sans-serif;
    min-height: 0;
  }

  .edi__drop {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.15rem;
    padding: 0.5rem;
    border: 1.5px dashed rgba(46, 125, 50, 0.35);
    border-radius: 7px;
    background: rgba(46, 125, 50, 0.04);
    text-align: center;
  }

  .edi__drop-title {
    font-size: 0.65rem;
    font-weight: 600;
    color: #111827;
  }

  .edi__drop-sub {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.48rem;
    color: #6b7280;
  }

  .edi__groups {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.32rem;
    min-height: 0;
  }

  .edi__group {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .edi__group-head {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.45rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #6b7280;
  }

  .edi__file {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.2rem 0.35rem;
    background: #f9fafb;
    border: 1px solid #f3f4f6;
    border-radius: 4px;
  }

  .edi__name {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.55rem;
    color: #111827;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .edi__status {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.45rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .edi__status--done      { color: #16a34a; }
  .edi__status--detected  { color: #2563eb; }
  .edi__status--analyzing { color: #2e7d32; }
  .edi__status--review    { color: #d97706; }

  .edi__spinner {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    border: 1.5px solid rgba(46, 125, 50, 0.2);
    border-top-color: #2e7d32;
    animation: edi-spin 0.8s linear infinite;
  }

  @keyframes edi-spin {
    to { transform: rotate(360deg); }
  }
</style>
