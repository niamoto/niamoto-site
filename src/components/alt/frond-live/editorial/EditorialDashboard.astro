---
/*
 * EditorialDashboard — faithful port of the updated app DashboardView.
 * Source of truth: src/niamoto/gui/ui/src/features/dashboard/
 * 3-stage pipeline (Data → Collections → Publication) with green-check "fresh"
 * status and flow arrows. Matches the current app UI as of 2026-04.
 */

import MacWindow from "./MacWindow.astro";
---

<MacWindow title="Niamoto" subtitle="Dashboard">
  <div class="edd">
    <!-- Header: title + "everything is up to date" subtitle -->
    <div class="edd__head">
      <div>
        <div class="edd__title">Dashboard</div>
        <div class="edd__status-line">Everything is up to date</div>
      </div>
      <div class="edd__project">
        <span class="edd__project-name">Nouvelle-Calédonie</span>
        <span class="edd__project-sub">Portail de la forêt</span>
      </div>
    </div>

    <!-- 3-stage pipeline row with flow arrows -->
    <div class="edd__pipeline">

      <!-- Data -->
      <div class="edd__stage">
        <div class="edd__stage-head">
          <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="edd__stage-check" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="17 9 11 15 7 11"/>
          </svg>
          <span class="edd__stage-title">Data</span>
        </div>
        <div class="edd__stage-count">205 650 rows</div>
        <div class="edd__stage-ago">6 d ago</div>
      </div>

      <span class="edd__arrow" aria-hidden="true">›</span>

      <!-- Collections -->
      <div class="edd__stage">
        <div class="edd__stage-head">
          <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="edd__stage-check" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="17 9 11 15 7 11"/>
          </svg>
          <span class="edd__stage-title">Collections</span>
        </div>
        <div class="edd__stage-count">3 groups</div>
        <div class="edd__stage-ago">17 min ago</div>
      </div>

      <span class="edd__arrow" aria-hidden="true">›</span>

      <!-- Publication -->
      <div class="edd__stage">
        <div class="edd__stage-head">
          <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="edd__stage-check" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="17 9 11 15 7 11"/>
          </svg>
          <span class="edd__stage-title">Publication</span>
        </div>
        <div class="edd__stage-count">3 593 pages</div>
        <div class="edd__stage-ago">11 min ago</div>
      </div>

    </div>

    <!-- Quick actions row -->
    <div class="edd__actions-label">Quick actions</div>
    <div class="edd__actions">
      <span class="edd__action">
        <svg viewBox="0 0 24 24" width="8" height="8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        Import
      </span>
      <span class="edd__action">
        <svg viewBox="0 0 24 24" width="8" height="8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
        Recalculate
      </span>
      <span class="edd__action">
        <svg viewBox="0 0 24 24" width="8" height="8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        Rebuild site
      </span>
      <span class="edd__action edd__action--muted">
        <svg viewBox="0 0 24 24" width="8" height="8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        Publish
      </span>
    </div>
  </div>
</MacWindow>

<style>
  .edd {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 0.55rem 0.7rem;
    gap: 0.45rem;
    font-family: "Plus Jakarta Sans", system-ui, -apple-system, sans-serif;
    color: #111827;
    min-height: 0;
  }

  .edd__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .edd__title {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: #111827;
  }

  .edd__status-line {
    margin-top: 0.05rem;
    font-size: 0.58rem;
    color: #16a34a;
    font-weight: 500;
  }

  .edd__project {
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .edd__project-name {
    font-size: 0.6rem;
    font-weight: 600;
    color: #111827;
  }

  .edd__project-sub {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.45rem;
    color: #6b7280;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Pipeline row: 3 stages + 2 arrows */
  .edd__pipeline {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: 0.3rem;
  }

  .edd__stage {
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
    padding: 0.45rem 0.55rem;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
  }

  .edd__stage-head {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .edd__stage-check {
    flex-shrink: 0;
  }

  .edd__stage-title {
    font-size: 0.6rem;
    font-weight: 600;
    color: #111827;
  }

  .edd__stage-count {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.56rem;
    color: #16a34a;
    font-weight: 600;
  }

  .edd__stage-ago {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.45rem;
    color: #9ca3af;
  }

  .edd__arrow {
    font-size: 0.85rem;
    color: #d1d5db;
    font-weight: 300;
    line-height: 1;
  }

  /* Quick actions */
  .edd__actions-label {
    margin-top: 0.15rem;
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.42rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9ca3af;
    font-weight: 600;
  }

  .edd__actions {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .edd__action {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.42rem;
    border-radius: 5px;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    font-size: 0.52rem;
    font-weight: 500;
    color: #374151;
  }

  .edd__action--muted {
    color: #9ca3af;
    background: #f9fafb;
  }
</style>
