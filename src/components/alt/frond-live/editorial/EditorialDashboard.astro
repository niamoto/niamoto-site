---
/*
 * EditorialDashboard — faithful port of the updated app DashboardView.
 * Source of truth: src/niamoto/gui/ui/src/features/dashboard/
 * 3-stage pipeline + quick actions + data breakdown + recent activity.
 * Matches current app UI as of 2026-04.
 */

import MacWindow from "./MacWindow.astro";
---

<MacWindow title="Niamoto" subtitle="Dashboard">
  <div class="edd">
    <!-- Header -->
    <div class="edd__head">
      <div class="edd__title">Dashboard</div>
      <div class="edd__status-line">Everything is up to date</div>
    </div>

    <!-- Pipeline row: 3 stages + flow arrows -->
    <div class="edd__pipeline">
      <div class="edd__stage">
        <div class="edd__stage-head">
          <svg viewBox="0 0 24 24" width="9" height="9" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="17 9 11 15 7 11"/></svg>
          <span class="edd__stage-title">Data</span>
        </div>
        <div class="edd__stage-count">205 650 rows</div>
        <div class="edd__stage-ago">6 d ago</div>
      </div>
      <span class="edd__arrow" aria-hidden="true">›</span>
      <div class="edd__stage">
        <div class="edd__stage-head">
          <svg viewBox="0 0 24 24" width="9" height="9" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="17 9 11 15 7 11"/></svg>
          <span class="edd__stage-title">Collections</span>
        </div>
        <div class="edd__stage-count">3 groups</div>
        <div class="edd__stage-ago">30 min ago</div>
      </div>
      <span class="edd__arrow" aria-hidden="true">›</span>
      <div class="edd__stage">
        <div class="edd__stage-head">
          <svg viewBox="0 0 24 24" width="9" height="9" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="17 9 11 15 7 11"/></svg>
          <span class="edd__stage-title">Publish</span>
        </div>
        <div class="edd__stage-count">3 593 pages</div>
        <div class="edd__stage-ago">24 min ago</div>
      </div>
    </div>

    <!-- Two panels: data breakdown + recent activity -->
    <div class="edd__panels">
      <div class="edd__panel">
        <div class="edd__panel-title">Data</div>
        <div class="edd__row"><span class="edd__row-name">occurrences</span><span class="edd__row-value">203 865</span></div>
        <div class="edd__row"><span class="edd__row-name">plots</span><span class="edd__row-value">22</span></div>
        <div class="edd__row"><span class="edd__row-name">taxons</span><span class="edd__row-value">1 667</span></div>
        <div class="edd__row edd__row--sep"><span class="edd__row-name">Publish</span><span class="edd__row-value">3 593 pages · 749 MB</span></div>
      </div>

      <div class="edd__panel">
        <div class="edd__panel-title">Recent activity</div>
        <div class="edd__activity">
          <span class="edd__activity-dot" style="background:#2e7d32" aria-hidden="true"></span>
          <div class="edd__activity-body">
            <div class="edd__activity-name">Export <span class="edd__activity-check">✓</span></div>
            <div class="edd__activity-meta">24 min ago · 249 s</div>
          </div>
        </div>
        <div class="edd__activity">
          <span class="edd__activity-dot" style="background:#d97706" aria-hidden="true"></span>
          <div class="edd__activity-body">
            <div class="edd__activity-name">Recalculate <span class="edd__activity-check">✓</span></div>
            <div class="edd__activity-meta">30 min ago · 92 s</div>
          </div>
        </div>
        <div class="edd__activity">
          <span class="edd__activity-dot" style="background:#3b82f6" aria-hidden="true"></span>
          <div class="edd__activity-body">
            <div class="edd__activity-name">Import <span class="edd__activity-check">✓</span></div>
            <div class="edd__activity-meta">6 days ago</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</MacWindow>

<style>
  .edd {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 0.45rem 0.55rem;
    gap: 0.35rem;
    font-family: "Plus Jakarta Sans", system-ui, -apple-system, sans-serif;
    color: #111827;
    min-height: 0;
  }

  .edd__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
  }

  .edd__title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: #111827;
  }

  .edd__status-line {
    font-size: 0.5rem;
    color: #16a34a;
    font-weight: 500;
  }

  /* Pipeline row: 3 stages + 2 arrows */
  .edd__pipeline {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: 0.2rem;
  }

  .edd__stage {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.3rem 0.4rem;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 5px;
  }

  .edd__stage-head {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .edd__stage-title {
    font-size: 0.54rem;
    font-weight: 600;
    color: #111827;
  }

  .edd__stage-count {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.5rem;
    color: #16a34a;
    font-weight: 600;
  }

  .edd__stage-ago {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.4rem;
    color: #9ca3af;
  }

  .edd__arrow {
    font-size: 0.7rem;
    color: #d1d5db;
    font-weight: 300;
    line-height: 1;
  }

  /* Two panels */
  .edd__panels {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.3rem;
    min-height: 0;
  }

  .edd__panel {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.35rem 0.45rem;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 5px;
    min-height: 0;
  }

  .edd__panel-title {
    font-size: 0.55rem;
    font-weight: 700;
    color: #111827;
    margin-bottom: 0.05rem;
  }

  .edd__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.4rem;
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
  }

  .edd__row--sep {
    margin-top: 0.1rem;
    padding-top: 0.2rem;
    border-top: 1px solid #f3f4f6;
  }

  .edd__row-name {
    font-size: 0.5rem;
    color: #6b7280;
  }

  .edd__row-value {
    font-size: 0.5rem;
    color: #111827;
    font-weight: 600;
  }

  .edd__activity {
    display: flex;
    gap: 0.35rem;
    align-items: flex-start;
  }

  .edd__activity-dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    margin-top: 0.15rem;
    flex-shrink: 0;
  }

  .edd__activity-body {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .edd__activity-name {
    font-size: 0.5rem;
    font-weight: 600;
    color: #111827;
  }

  .edd__activity-check {
    color: #16a34a;
    margin-left: 0.15rem;
  }

  .edd__activity-meta {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.4rem;
    color: #9ca3af;
  }
</style>
