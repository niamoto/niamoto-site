---
/*
 * EditorialPublish — faithful port of the app's Publish deploy success state.
 * Source of truth: src/niamoto/gui/ui/src/features/publish/views/deploy.tsx
 * Real providers (cloudflare, netlify, github-pages), real success UI.
 */

import MacWindow from "./MacWindow.astro";
---

<MacWindow title="Niamoto" subtitle="Publish">
  <div class="edp">
    <!-- Header -->
    <div class="edp__head">
      <div>
        <div class="edp__title">Deploy</div>
        <div class="edp__eyebrow">Last deployment · 2 min ago</div>
      </div>
      <span class="edp__chip edp__chip--live">
        <span class="edp__chip-dot" aria-hidden="true"></span>
        Live
      </span>
    </div>

    <!-- Main success card -->
    <div class="edp__card">
      <div class="edp__card-head">
        <span class="edp__check" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <div class="edp__card-meta">
          <div class="edp__card-title">Portal published</div>
          <div class="edp__card-sub">GitHub Pages · built in 2.4 s</div>
        </div>
      </div>

      <div class="edp__url">
        <span class="edp__url-arrow">→</span>
        <span class="edp__url-value">niamoto.github.io/nc-2025</span>
        <svg viewBox="0 0 24 24" width="8" height="8" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="edp__url-external" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </div>

      <div class="edp__meta">
        <div class="edp__meta-item">
          <span class="edp__meta-value">216</span>
          <span class="edp__meta-label">pages</span>
        </div>
        <div class="edp__meta-item">
          <span class="edp__meta-value">3.8</span>
          <span class="edp__meta-label">MB bundle</span>
        </div>
        <div class="edp__meta-item">
          <span class="edp__meta-value">42</span>
          <span class="edp__meta-label">assets</span>
        </div>
      </div>
    </div>

    <!-- Providers strip -->
    <div class="edp__providers">
      <span class="edp__providers-label">Also connected</span>
      <div class="edp__providers-row">
        <span class="edp__provider">GitHub Pages <span class="edp__provider-dot edp__provider-dot--live" aria-hidden="true"></span></span>
        <span class="edp__provider edp__provider--idle">Cloudflare</span>
        <span class="edp__provider edp__provider--idle">Netlify</span>
      </div>
    </div>
  </div>
</MacWindow>

<style>
  .edp {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 0.55rem 0.7rem;
    gap: 0.45rem;
    font-family: "Plus Jakarta Sans", system-ui, -apple-system, sans-serif;
    color: #111827;
    min-height: 0;
  }

  .edp__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .edp__title {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: #111827;
  }

  .edp__eyebrow {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.46rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #9ca3af;
    font-weight: 500;
    margin-top: 0.1rem;
  }

  .edp__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.18rem 0.38rem;
    border-radius: 9999px;
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.48rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .edp__chip--live {
    background: #d1fae5;
    color: #047857;
  }

  .edp__chip-dot {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.15);
  }

  .edp__card {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 7px;
    padding: 0.55rem 0.7rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    position: relative;
    overflow: hidden;
  }

  .edp__card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2.5px;
    background: linear-gradient(90deg, #228b22, #2d8f47, #4caf50);
  }

  .edp__card-head {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.15rem;
  }

  .edp__check {
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 50%;
    background: #10b981;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .edp__card-title {
    font-size: 0.68rem;
    font-weight: 700;
    color: #111827;
  }

  .edp__card-sub {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.48rem;
    color: #6b7280;
    margin-top: 0.05rem;
  }

  .edp__url {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.32rem 0.45rem;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 5px;
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.58rem;
  }

  .edp__url-arrow {
    color: #9ca3af;
  }

  .edp__url-value {
    flex: 1;
    color: #2e7d32;
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .edp__meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.35rem;
  }

  .edp__meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    padding: 0.2rem 0.3rem;
    background: #f9fafb;
    border-radius: 4px;
  }

  .edp__meta-value {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    color: #111827;
    letter-spacing: -0.02em;
  }

  .edp__meta-label {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.42rem;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .edp__providers {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .edp__providers-label {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.42rem;
    color: #9ca3af;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .edp__providers-row {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .edp__provider {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.52rem;
    font-weight: 500;
    background: #f3f4f6;
    color: #374151;
    border: 1px solid #e5e7eb;
  }

  .edp__provider--idle {
    color: #9ca3af;
    background: #ffffff;
  }

  .edp__provider-dot {
    width: 0.3rem;
    height: 0.3rem;
    border-radius: 50%;
  }

  .edp__provider-dot--live {
    background: #10b981;
    box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.15);
  }
</style>
