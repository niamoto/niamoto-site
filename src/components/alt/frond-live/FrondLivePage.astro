---
import AltLayout from "@/layouts/AltLayout.astro";
import FrondHeader from "./FrondHeader.astro";
import type { Locale } from "@/i18n/config";
import enCopy from "@/i18n/alt/frond-live.en";
import frCopy from "@/i18n/alt/frond-live.fr";
import {
  buildReleaseDownloads,
  LATEST_JSON,
  LATEST_RELEASE_API,
  type Downloads,
  type GitHubLatestRelease,
  type TauriLatest,
} from "@/lib/release-downloads";

import FrondLiveHero from "./FrondLiveHero.astro";

// Non-hero sections are reused as-is from the original frond/ directory.
import FrondWidgetBand from "../frond/FrondWidgetBand.astro";
import FrondPillars from "../frond/FrondPillars.astro";
import FrondReading from "../frond/FrondReading.astro";
import FrondSequence from "../frond/FrondSequence.astro";
import FrondShowcase from "../frond/FrondShowcase.astro";
import FrondTwoWays from "../frond/FrondTwoWays.astro";
import FrondPrinciples from "../frond/FrondPrinciples.astro";
import FrondClosing from "../frond/FrondClosing.astro";
import FrondFooter from "@/components/alt/shared/FrondFooter.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = locale === "fr" ? frCopy : enCopy;

let tauri: TauriLatest | null = null;
let release: GitHubLatestRelease | null = null;

try {
  const res = await fetch(LATEST_JSON);
  if (res.ok) {
    tauri = (await res.json()) as TauriLatest;
  } else {
    console.warn(`[latest.json] HTTP ${res.status} — fallback partiel`);
  }
} catch (err) {
  console.warn(`[latest.json] fetch failed (${(err as Error).message}) — fallback partiel`);
}

try {
  const res = await fetch(LATEST_RELEASE_API, {
    headers: {
      Accept: "application/vnd.github+json",
    },
  });
  if (res.ok) {
    release = (await res.json()) as GitHubLatestRelease;
  } else {
    console.warn(`[latest release] HTTP ${res.status} — fallback partiel`);
  }
} catch (err) {
  console.warn(`[latest release] fetch failed (${(err as Error).message}) — fallback partiel`);
}

const downloads: Downloads = buildReleaseDownloads({ release, tauri });
---

<AltLayout
  theme="frond"
  locale={locale}
  title={t.meta.title}
  description={t.meta.description}
>
  <a href="#main" class="skip-link">Skip to content</a>
  <FrondHeader locale={locale} />

  <main id="main" class="frond-shell">
    <FrondLiveHero {...t.hero} downloads={downloads} />
    <FrondWidgetBand {...t.widgetBand} />
    <FrondPillars {...t.pillars} />
    <FrondReading locale={locale} {...t.reading} />
    <FrondSequence {...t.sequence} />
    <FrondShowcase locale={locale} {...t.showcase} />
    <FrondTwoWays {...t.twoWays} />
    <FrondPrinciples {...t.principles} />
    <FrondClosing
      eyebrow={t.closing.eyebrow}
      title={t.closing.title}
      body={t.closing.body}
      ctaPrimary={t.closing.ctaPrimary}
      ctaSecondary={t.closing.ctaSecondary}
      license={t.closing.license}
      fundersHeading={t.funders.heading}
      fundersSubtitle={t.funders.subtitle}
    />
  </main>
  <FrondFooter locale={locale} />
</AltLayout>
