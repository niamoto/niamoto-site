---
interface PortalItem {
  code: string;
  name: string;
  status: "active" | "upcoming";
}

interface Props {
  kicker: string;
  items: readonly PortalItem[];
}

const { kicker, items } = Astro.props;
---

<div class="meth-portals bento-card">
  <span class="meth-portals__kicker">{kicker}</span>
  <ul class="meth-portals__list">
    {items.map((p) => (
      <li class={`meth-portal meth-portal--${p.status}`}>
        <span class="meth-portal__code">{p.code}</span>
        <span class="meth-portal__name">{p.name}</span>
        <span class={`meth-portal__dot meth-portal__dot--${p.status}`} aria-hidden="true"></span>
      </li>
    ))}
  </ul>
</div>

<style>
  .meth-portals {
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
  }
  .meth-portals__kicker {
    font-family: var(--f-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--c-muted);
  }
  .meth-portals__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    justify-content: center;
  }
  .meth-portal {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.6rem;
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.02);
  }
  .meth-portal__code {
    font-family: var(--f-mono);
    font-size: 0.7rem;
    color: var(--c-accent);
    letter-spacing: 0.08em;
    width: 2.5rem;
  }
  .meth-portal__name {
    font-size: 0.85rem;
    color: var(--c-ink);
  }
  .meth-portal__dot {
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: var(--c-hairline);
  }
  .meth-portal__dot--active {
    background: var(--c-accent);
    animation: methPulse 2s ease-in-out infinite;
  }
  @keyframes methPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }
  @media (prefers-reduced-motion: reduce) {
    .meth-portal__dot--active { animation: none; }
  }
</style>
