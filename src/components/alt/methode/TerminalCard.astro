---
import InfiniteTypewriter from "@/components/alt/motion/InfiniteTypewriter.tsx";

interface Props {
  kicker: string;
  lines: readonly string[];
}

const { kicker, lines } = Astro.props;
---

<div class="meth-terminal bento-card">
  <div class="meth-terminal__head">
    <span class="meth-terminal__kicker">{kicker}</span>
    <span class="meth-terminal__dots" aria-hidden="true">
      <span></span><span></span><span></span>
    </span>
  </div>
  <div class="meth-terminal__body">
    <InfiniteTypewriter
      client:visible
      lines={lines as unknown as string[]}
      prompt="$ "
      typeMs={45}
      holdMs={2200}
      deleteMs={22}
      className="meth-terminal__pre"
    />
  </div>
</div>

<style>
  .meth-terminal {
    padding: 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .meth-terminal__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .meth-terminal__kicker {
    font-family: var(--f-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--c-muted);
  }
  .meth-terminal__dots {
    display: inline-flex;
    gap: 0.35rem;
  }
  .meth-terminal__dots span {
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: var(--c-hairline);
  }
  .meth-terminal__body {
    flex: 1;
    border-radius: 0.75rem;
    background: rgba(0, 0, 0, 0.35);
    padding: 1rem 1.1rem;
    overflow: hidden;
  }
  .meth-terminal :global(.meth-terminal__pre) {
    margin: 0;
    font-family: var(--f-mono);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--c-ink);
    white-space: pre-wrap;
    word-break: break-word;
  }
</style>
