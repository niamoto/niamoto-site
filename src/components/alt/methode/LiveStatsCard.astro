---
import AnimatedCounter from "@/components/alt/motion/AnimatedCounter.tsx";

interface StatItem {
  value: number;
  label: string;
  suffix?: string;
}

interface Props {
  kicker: string;
  items: readonly StatItem[];
  /** Locale used for number formatting. */
  locale: "en" | "fr";
}

const { kicker, items, locale } = Astro.props;
const numberLocale = locale === "fr" ? "fr-FR" : "en-US";
---

<div class="meth-stats bento-card">
  <span class="meth-stats__kicker">{kicker}</span>
  <ul class="meth-stats__grid">
    {items.map((s) => (
      <li>
        <AnimatedCounter
          client:visible
          value={s.value}
          suffix={s.suffix ?? ""}
          locale={numberLocale}
          durationMs={1300}
          className="meth-stats__value stat-number"
        />
        <span class="meth-stats__label">{s.label}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .meth-stats {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    height: 100%;
  }
  .meth-stats__kicker {
    font-family: var(--f-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--c-muted);
  }
  .meth-stats__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem 2rem;
    flex: 1;
    align-content: center;
  }
  .meth-stats__grid li {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .meth-stats :global(.meth-stats__value) {
    font-family: var(--f-mono);
    font-variant-numeric: tabular-nums;
    font-size: 1.8rem;
    color: var(--c-ink);
    line-height: 1;
  }
  .meth-stats__label {
    font-family: var(--f-body);
    font-size: 0.78rem;
    color: var(--c-muted);
    line-height: 1.3;
  }
</style>
