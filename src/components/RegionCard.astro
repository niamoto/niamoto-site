---
import Pill from "./Pill.astro";

export interface Props {
  name: string;
  subregion: string;
  body: string;
  status: "active" | "upcoming";
  silhouette: "nc" | "gabon-cameroun" | "guyane";
  visitUrl?: string;
}

const { name, subregion, body, status, silhouette, visitUrl } = Astro.props;

const silhouetteColor = status === "active" ? "#4BAF50" : "#5B86B0";
const silhouetteFill = status === "active" ? "rgba(75,175,80,0.15)" : "rgba(91,134,176,0.12)";

// Simple abstract silhouettes — not cartographic, just recognizable shapes
const silhouettes = {
  nc: "M20 25 Q 50 15, 80 20 Q 100 22, 105 25 Q 90 32, 60 33 Q 30 34, 20 25 Z",
  "gabon-cameroun":
    "M30 15 Q 40 10, 60 12 Q 80 15, 85 25 Q 82 35, 78 42 Q 70 45, 55 43 Q 35 40, 28 30 Q 25 20, 30 15 Z",
  guyane:
    "M35 15 Q 65 12, 85 18 Q 90 25, 75 38 Q 60 42, 45 40 Q 30 32, 32 22 Z",
};
---

<div
  class="flex flex-col rounded-[12px] bg-white p-7 shadow-[0_4px_12px_rgba(15,23,42,0.06)]"
>
  {/* Silhouette */}
  <div class="flex justify-center pb-5">
    <svg
      width="120"
      height="50"
      viewBox="0 0 120 50"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path
        d={silhouettes[silhouette]}
        fill={silhouetteFill}
        stroke={silhouetteColor}
        stroke-width="2"
      />
    </svg>
  </div>

  {/* Status */}
  <div class="mb-3">
    {
      status === "active" ? (
        <Pill variant="leaf">● Active</Pill>
      ) : (
        <Pill variant="steel">● Upcoming 2026</Pill>
      )
    }
  </div>

  {/* Title */}
  <h3 class="text-xl font-bold text-ink">{name}</h3>
  <p class="mt-0.5 text-sm text-stone">{subregion}</p>

  {/* Body */}
  <p class="mt-3 flex-1 text-sm leading-relaxed text-ink/80">{body}</p>

  {/* Footer link / caption */}
  <div class="mt-4">
    {
      visitUrl ? (
        <a
          href={visitUrl}
          class="text-sm font-medium text-steel-blue hover:underline"
        >
          Visit portal →
        </a>
      ) : (
        <span class="text-sm text-stone opacity-60">Coming 2026</span>
      )
    }
  </div>
</div>
