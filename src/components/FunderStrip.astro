---
// Horizontal strip of 9 partner logos — unified "Nos partenaires" display.
// Data comes from public/funders/manifest.yaml but we hard-code the order here
// for layout stability. Roles (funder/partner_research/partner_data) are
// available in the manifest for future filtering.

const partners = [
  { id: "pn", name: "Province Nord", url: "https://www.province-nord.nc" },
  { id: "ps", name: "Province Sud", url: "https://www.province-sud.nc" },
  { id: "ofb", name: "OFB", url: "https://www.ofb.gouv.fr" },
  { id: "ird", name: "IRD", url: "https://nouvelle-caledonie.ird.fr" },
  { id: "cirad", name: "CIRAD", url: "https://www.cirad.fr" },
  { id: "amap", name: "UMR AMAP", url: "https://amap.cirad.fr" },
  { id: "iac", name: "IAC", url: "https://iac.nc" },
  { id: "endemia", name: "Endemia", url: "https://endemia.nc" },
  {
    id: "herbarium",
    name: "Herbier de Nouvelle-Calédonie",
    url: "http://publish.plantnet-project.org/project/herbier-noumea",
  },
];
---

<section class="bg-surface-low py-16">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mb-10 text-center">
      <h2 class="text-xl font-bold text-ink">Our partners</h2>
      <p class="mt-1 text-sm text-stone">
        Funders, research institutions, and data providers
      </p>
    </div>

    <div
      class="flex flex-wrap items-center justify-center gap-x-10 gap-y-8"
    >
      {
        partners.map((p) => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex flex-col items-center gap-2 transition-opacity hover:opacity-100"
            title={p.name}
          >
            <img
              src={`/funders/${p.id}_100.png`}
              alt={p.name}
              class="h-12 w-auto max-w-[120px] object-contain grayscale opacity-75 transition-all group-hover:grayscale-0 group-hover:opacity-100"
              loading="lazy"
              decoding="async"
            />
            <span class="font-mono text-[10px] uppercase tracking-wider text-stone">
              {p.name}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
