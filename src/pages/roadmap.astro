---
import AltLayout from "@/layouts/AltLayout.astro";
import FrondHeader from "@/components/alt/frond-live/FrondHeader.astro";
import FrondFooter from "@/components/alt/shared/FrondFooter.astro";
import FadeUpOnView from "@/components/alt/motion/FadeUpOnView.tsx";
import { getEntry } from "astro:content";
import { marked, Renderer, type Token, type Tokens } from "marked";
import { rewriteNiamotoLinks } from "@/lib/rewrite-niamoto-links";

interface Props {
  locale?: "en" | "fr";
}
const { locale = "en" } = Astro.props;

const entry = await getEntry("roadmap", "content");
if (!entry) throw new Error("Roadmap content not loaded");

const renderer = new Renderer();
type InlineTokenBlock = (Tokens.Paragraph | Tokens.Text) & { tokens: Token[] };

function hasInlineTokens(
  token: Token | undefined,
): token is InlineTokenBlock {
  return Boolean(token && "tokens" in token && Array.isArray(token.tokens));
}

function stripLeadSeparator(token: Token): Token {
  if (token.type !== "text") return token;

  return {
    ...token,
    raw: token.raw.replace(/^\s*(?:—|–|-|:)\s*/, ""),
    text: token.text.replace(/^\s*(?:—|–|-|:)\s*/, ""),
  };
}

renderer.listitem = function (item: Tokens.ListItem) {
  const firstBlock = item.tokens[0];

  if (hasInlineTokens(firstBlock)) {
    const [leadToken, ...restTokens] = firstBlock.tokens;

    if (leadToken?.type === "strong" && restTokens.length > 0) {
      const leadStrong = leadToken as Tokens.Strong;
      const title = this.parser.parseInline(leadStrong.tokens);
      const bodyTokens = restTokens.map((token, index) =>
        index === 0 ? stripLeadSeparator(token) : token,
      );
      const body = this.parser.parseInline(bodyTokens).trim();
      const extraBlocks = item.tokens.slice(1);
      const extra = extraBlocks.length > 0 ? this.parser.parse(extraBlocks) : "";

      return `<li><span class="roadmap-item-title">${title}</span>${body ? `<span class="roadmap-item-copy">${body}</span>` : ""}${extra}</li>\n`;
    }
  }

  return `<li>${this.parser.parse(item.tokens)}</li>\n`;
};

const rewritten = rewriteNiamotoLinks(entry.data.body);
const html = await marked.parse(rewritten, { gfm: true, breaks: false, renderer });

const t = locale === "fr"
  ? {
      title: "Feuille de route",
      lead: "Ce qui se prépare, ce qui vient, ce qui est à l'horizon.",
    }
  : {
      title: "Roadmap",
      lead: "What's shipping, what's next, what's on the horizon.",
    };
---

<AltLayout
  theme="frond"
  locale={locale}
  title={locale === "fr" ? "Feuille de route — Niamoto" : "Roadmap — Niamoto"}
  description="Niamoto roadmap — current focus, upcoming milestones, and longer-term plans."
>
  <FrondHeader locale={locale} />

  <section class="border-b border-hairline py-16" style="background: var(--c-surface-muted)">
    <div class="mx-auto max-w-[760px] px-6 text-center">
      <FadeUpOnView client:visible blur={0}>
        <h1 class="text-5xl font-bold tracking-[-0.02em] text-ink">{t.title}</h1>
        <p class="mx-auto mt-3 max-w-[600px] text-lg text-muted">{t.lead}</p>
      </FadeUpOnView>
    </div>
  </section>

  <section class="roadmap-body">
    <FadeUpOnView client:visible>
      <article class="niamoto-prose" set:html={html} />
    </FadeUpOnView>
  </section>

  <FrondFooter locale={locale} />
</AltLayout>

<style is:global>
  .niamoto-prose {
    max-width: 52rem;
    margin: 0 auto;
    color: color-mix(in srgb, var(--c-ink) 90%, transparent);
    font-size: 1.02rem;
    line-height: 1.72;
  }
  .roadmap-body {
    max-width: 58rem;
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 4.75rem) 1.5rem;
  }
  .niamoto-prose > h1 {
    display: none;
  }
  .niamoto-prose h2 {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-top: clamp(3.25rem, 7vw, 4.5rem);
    margin-bottom: 0.9rem;
    padding-top: 2.15rem;
    border-top: 1px solid var(--c-hairline);
    font-size: clamp(1.65rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -0.025em;
  }
  .niamoto-prose h2:first-of-type {
    margin-top: 0;
  }
  .niamoto-prose h2::before {
    content: "";
    flex: 0 0 auto;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--c-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--c-accent) 10%, transparent);
  }
  .niamoto-prose h3 {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--c-ink);
  }
  .niamoto-prose p {
    margin: 1rem 0;
    max-width: 44rem;
  }
  .niamoto-prose ul, .niamoto-prose ol {
    display: grid;
    gap: 0.7rem;
    margin: 1.15rem 0 1.6rem;
    padding-left: 0;
    list-style: none;
  }
  .niamoto-prose > ul > li,
  .niamoto-prose > ol > li {
    position: relative;
    margin: 0;
    border: 1px solid var(--c-hairline);
    border-left: 3px solid color-mix(in srgb, var(--c-accent-alt) 62%, var(--c-hairline));
    border-radius: 7px;
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--c-accent-alt) 7%, transparent),
        transparent 42%
      ),
      color-mix(in srgb, var(--c-surface) 88%, transparent);
    box-shadow: var(--shadow-sm);
    color: color-mix(in srgb, var(--c-ink) 82%, transparent);
  }
  .niamoto-prose > ul > li {
    padding: 0.85rem 1rem 0.9rem 1.2rem;
  }
  .niamoto-prose > ul > li::before {
    content: "";
    position: absolute;
    top: 1.36rem;
    left: -0.42rem;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--c-accent-alt);
    box-shadow: 0 0 0 3px var(--c-canvas);
  }
  .niamoto-prose > ol {
    counter-reset: roadmap-step;
  }
  .niamoto-prose > ol > li {
    counter-increment: roadmap-step;
    padding: 0.85rem 1rem 0.9rem 3.45rem;
  }
  .niamoto-prose > ol > li::before {
    content: counter(roadmap-step, decimal-leading-zero);
    position: absolute;
    top: 0.92rem;
    left: 0.95rem;
    font-family: var(--f-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: var(--c-accent);
    background: color-mix(in srgb, var(--c-accent) 9%, var(--c-surface));
    border: 1px solid color-mix(in srgb, var(--c-accent) 18%, var(--c-hairline));
    border-radius: 999px;
    padding: 0.22rem 0.42rem;
  }
  .niamoto-prose li > strong:first-child {
    color: var(--c-ink);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .niamoto-prose .roadmap-item-title {
    display: block;
    margin-bottom: 0.25rem;
    color: var(--c-ink);
    font-weight: 700;
    letter-spacing: -0.012em;
    line-height: 1.35;
  }
  .niamoto-prose .roadmap-item-copy {
    display: block;
    color: color-mix(in srgb, var(--c-ink) 76%, transparent);
  }
  .niamoto-prose li p {
    max-width: none;
    margin: 0.45rem 0 0;
  }
  .niamoto-prose a {
    color: var(--c-accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--c-accent) 40%, transparent);
  }
  .niamoto-prose a:hover {
    border-bottom-color: var(--c-accent);
  }
  .niamoto-prose code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--c-surface-muted);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
  }
  .niamoto-prose strong {
    color: var(--c-ink);
    font-weight: 600;
  }
  .niamoto-prose hr {
    margin: 2.5rem 0;
    border: 0;
    border-top: 1px solid var(--c-hairline);
  }
  .niamoto-prose blockquote {
    margin: 1.5rem 0;
    padding-left: 1.25rem;
    border-left: 3px solid var(--c-hairline);
    color: var(--c-muted);
  }
  @media (max-width: 640px) {
    .roadmap-body {
      padding-inline: 1rem;
    }
    .niamoto-prose {
      font-size: 0.98rem;
    }
    .niamoto-prose > ul > li {
      padding: 0.8rem 0.85rem 0.85rem 1rem;
    }
    .niamoto-prose > ol > li {
      padding: 0.8rem 0.85rem 0.85rem 3.1rem;
    }
  }
</style>
