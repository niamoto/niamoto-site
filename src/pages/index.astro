---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Button from "@/components/Button.astro";
import Pill from "@/components/Pill.astro";
import FunderStrip from "@/components/FunderStrip.astro";
import RegionCard from "@/components/RegionCard.astro";
import DownloadButton from "@/components/DownloadButton.astro";

const pillars = [
  {
    title: "Import any ecological data",
    body: "CSV, GeoPackage, GeoJSON, raster. Auto-configuration detects your file types and maps fields.",
    icon: "database",
    color: "#5B86B0",
    snippet: `sources:
  occurrences:
    type: csv
    path: occurrences.csv`,
  },
  {
    title: "Transform with plugins",
    body: "Declarative YAML transforms turn raw data into statistics, distributions, and widgets. Plugin-based — extend what is missing.",
    icon: "layers",
    color: "#4BAF50",
  },
  {
    title: "Publish a static portal",
    body: "Auto-generated site with maps, charts, taxon pages. Deploy anywhere — GitHub Pages, Netlify, your own server.",
    icon: "globe",
    color: "#2E7D32",
  },
];

const showcases = [
  {
    region: "Nouvelle-Calédonie",
    status: "active" as const,
    title: "Forest Portal — New Caledonia",
    partners: "Province Nord, Province Sud, IRD, IAC",
    image: "/showcase/nc-home.png",
    href: "/showcase/nouvelle-caledonie",
  },
  {
    region: "Gabon – Cameroun",
    status: "upcoming" as const,
    title: "Congo Basin Forest Portal",
    partners: "Partners to be announced",
  },
  {
    region: "Guyane",
    status: "upcoming" as const,
    title: "Amazonian Flora Portal",
    partners: "Partners to be announced",
  },
];
---

<BaseLayout
  title="Niamoto — From field data to publishable ecological portals"
  description="Open-source platform that transforms ecological field data into shareable web portals. Import, transform with plugins, publish a static site."
>
  <Header />

  <!-- HERO — Minimalist variant -->
  <section
    class="relative mx-auto flex max-w-[1200px] flex-col items-center px-6 py-32 text-center"
    id="download"
  >
    <Pill variant="leaf">OPEN SOURCE</Pill>

    <h1
      class="mt-8 max-w-[900px] text-[64px] font-bold leading-[1.05] tracking-[-0.03em] text-ink"
    >
      From field data to publishable ecological portals
    </h1>

    <p class="mt-6 max-w-[640px] text-lg text-stone">
      Niamoto turns occurrence records, taxa inventories, and plot data into
      shareable web portals. Open source, plugin-based, built for ecologists.
    </p>

    <div class="mt-10 flex flex-col items-center gap-5">
      <DownloadButton size="lg" />

      <div
        class="flex items-center gap-2 rounded-[8px] border border-border bg-white px-4 py-2 font-mono text-xs text-stone"
      >
        <span>pip install niamoto</span>
        <button
          type="button"
          class="text-stone hover:text-ink"
          aria-label="Copy install command"
          data-copy="pip install niamoto"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
        </button>
      </div>
    </div>
  </section>

  <!-- PARTNERS -->
  <FunderStrip />

  <!-- DEPLOYED ACROSS ECOSYSTEMS -->
  <section class="bg-canvas py-24">
    <div class="mx-auto max-w-[1200px] px-6">
      <div class="mb-12 text-center">
        <h2 class="text-[28px] font-bold text-ink">Deployed across ecosystems</h2>
        <p class="mt-2 text-[15px] text-stone">
          Niamoto powers ecological portals on three continents
        </p>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        <RegionCard
          name="Nouvelle-Calédonie"
          subregion="South Pacific"
          body="Portail de la forêt, live since 2024. Tracks taxa, occurrences, and plot inventories across the main island."
          status="active"
          silhouette="nc"
          visitUrl="/showcase/nouvelle-caledonie"
        />
        <RegionCard
          name="Gabon – Cameroun"
          subregion="Central Africa"
          body="Portail des forêts du Bassin du Congo. Tropical rainforest inventories across two countries."
          status="upcoming"
          silhouette="gabon-cameroun"
        />
        <RegionCard
          name="Guyane"
          subregion="Northern South America"
          body="Portail de la flore amazonienne. Amazonian biodiversity catalog in progress."
          status="upcoming"
          silhouette="guyane"
        />
      </div>
    </div>
  </section>

  <!-- THREE PILLARS -->
  <section class="py-24">
    <div class="mx-auto max-w-[1200px] px-6">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {
          pillars.map((p) => (
            <div class="rounded-[12px] bg-white p-7 shadow-[0_4px_12px_rgba(15,23,42,0.06)]">
              <div
                class="mb-4 flex h-10 w-10 items-center justify-center rounded-[8px]"
                style={`background: ${p.color}18`}
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={p.color} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  {p.icon === "database" && (
                    <>
                      <ellipse cx="12" cy="5" rx="9" ry="3" />
                      <path d="M21 12c0 1.66-4.03 3-9 3s-9-1.34-9-3" />
                      <path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5" />
                    </>
                  )}
                  {p.icon === "layers" && (
                    <>
                      <path d="M12 2 2 7l10 5 10-5-10-5z" />
                      <path d="m2 17 10 5 10-5" />
                      <path d="m2 12 10 5 10-5" />
                    </>
                  )}
                  {p.icon === "globe" && (
                    <>
                      <circle cx="12" cy="12" r="10" />
                      <path d="M2 12h20" />
                      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                    </>
                  )}
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-ink">{p.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink/80">{p.body}</p>
              {p.snippet && (
                <pre class="mt-4 overflow-auto rounded-[8px] bg-[#16161A] p-3 font-mono text-[11px] leading-relaxed text-[#E5E7EB]"><code>{p.snippet}</code></pre>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SHOWCASE -->
  <section class="bg-canvas py-24">
    <div class="mx-auto max-w-[1200px] px-6">
      <div class="mb-12 text-center">
        <h2 class="text-[28px] font-bold text-ink">
          Live portals built with Niamoto
        </h2>
        <p class="mt-2 text-[15px] text-stone">
          Real ecological datasets, published with Niamoto
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {
          showcases.map((s) => (
            <div class="overflow-hidden rounded-[12px] bg-white shadow-[0_4px_12px_rgba(15,23,42,0.06)]">
              <div class="relative aspect-[16/10] bg-surface-low">
                {s.image ? (
                  <img
                    src={s.image}
                    alt={s.title}
                    class="h-full w-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-[#2E7D32]/10 to-[#5B86B0]/10">
                    <span class="font-mono text-sm text-stone">
                      Coming 2026
                    </span>
                  </div>
                )}
                <div class="absolute left-3 top-3">
                  {s.status === "active" ? (
                    <Pill variant="leaf">● Active</Pill>
                  ) : (
                    <Pill variant="steel">● Upcoming 2026</Pill>
                  )}
                </div>
              </div>
              <div class="p-5">
                <h3 class="text-base font-semibold text-ink">{s.title}</h3>
                <p class="mt-1 text-sm text-stone">{s.partners}</p>
                {s.href && (
                  <a
                    href={s.href}
                    class="mt-3 inline-block text-sm font-medium text-steel-blue hover:underline"
                  >
                    Visit →
                  </a>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- TWO WAYS TO USE -->
  <section class="bg-[#EEF2F5] py-24">
    <div class="mx-auto max-w-[1200px] px-6">
      <div class="mb-12 text-center">
        <h2 class="text-[28px] font-bold text-ink">Two ways to use Niamoto</h2>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        <div class="rounded-[12px] bg-white p-8 shadow-[0_4px_12px_rgba(15,23,42,0.06)]">
          <h3 class="text-xl font-semibold text-ink">Desktop app</h3>
          <p class="mt-1 text-sm text-stone">For scientists and field teams</p>
          <p class="mt-4 text-sm leading-relaxed text-ink/80">
            Drag-and-drop your data, configure collections visually, publish in
            one click. Available for macOS, Windows, and Linux.
          </p>
          <div class="mt-6">
            <DownloadButton size="md" showAlternatives={false} />
          </div>
        </div>

        <div class="rounded-[12px] bg-[#16161A] p-8 shadow-[0_4px_12px_rgba(15,23,42,0.06)]">
          <h3 class="text-xl font-semibold text-white">CLI + Python library</h3>
          <p class="mt-1 text-sm text-[#9AA3B4]">
            For developers and automation
          </p>
          <pre class="mt-4 overflow-auto rounded-[8px] bg-black/40 p-4 font-mono text-[13px] leading-relaxed text-[#E5E7EB]"><code>pip install niamoto
niamoto init my-project
niamoto run --all</code></pre>
          <a
            href="/documentation"
            class="mt-4 inline-block text-sm font-medium text-[#6FB3DD] hover:text-white"
          >
            Read the docs →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- OPEN SOURCE CALLOUT -->
  <section class="py-24">
    <div class="mx-auto max-w-[800px] px-6 text-center">
      <Pill variant="leaf">Open source</Pill>
      <h2 class="mt-5 text-[32px] font-bold leading-tight text-ink">
        Built in the open, for the scientific community
      </h2>
      <p class="mt-4 text-[17px] text-stone">
        Apache 2.0 licensed. Maintained by Arsis. Pull requests welcome.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <Button
          variant="outline"
          href="https://github.com/niamoto/niamoto"
          size="sm"
        >
          ★ Star on GitHub
        </Button>
        <a
          href="https://github.com/niamoto/niamoto/discussions"
          class="text-sm font-medium text-steel-blue hover:underline"
        >
          Join Discussions
        </a>
        <a
          href="https://github.com/niamoto/niamoto/releases"
          class="text-sm font-medium text-steel-blue hover:underline"
        >
          Read the changelog
        </a>
      </div>
      <div class="mt-10 border-t border-border pt-6">
        <a
          href="/alt/"
          class="text-xs font-mono uppercase tracking-[0.18em] text-stone hover:text-ink"
        >
          Explore alternative designs &rarr;
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  // Copy-to-clipboard for inline code snippets
  document
    .querySelectorAll<HTMLButtonElement>("[data-copy]")
    .forEach((btn) => {
      btn.addEventListener("click", async () => {
        const text = btn.dataset.copy ?? "";
        try {
          await navigator.clipboard.writeText(text);
          btn.innerHTML = "✓";
          setTimeout(() => {
            btn.innerHTML =
              '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
          }, 1500);
        } catch {
          /* ignore */
        }
      });
    });
</script>
