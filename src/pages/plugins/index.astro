---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Button from "@/components/Button.astro";

type PluginType = "transformer" | "widget" | "loader" | "exporter";

const typeStyle: Record<
  PluginType,
  { label: string; bg: string; color: string }
> = {
  transformer: {
    label: "TRANSFORMER",
    bg: "rgba(75, 175, 80, 0.12)",
    color: "#2E7D32",
  },
  widget: {
    label: "WIDGET",
    bg: "rgba(91, 134, 176, 0.12)",
    color: "#5B86B0",
  },
  loader: {
    label: "LOADER",
    bg: "rgba(147, 51, 234, 0.12)",
    color: "#9333EA",
  },
  exporter: {
    label: "EXPORTER",
    bg: "rgba(46, 125, 50, 0.14)",
    color: "#2E7D32",
  },
};

const plugins: Array<{
  name: string;
  type: PluginType;
  body: string;
  usedBy: number;
  version: string;
}> = [
  { name: "binary_counter", type: "transformer", body: "Count occurrences of binary values in a field (e.g., endemic/non-endemic, fertile/sterile).", usedBy: 24, version: "1.4.0" },
  { name: "geographic_distribution_map", type: "widget", body: "Interactive Leaflet map with occurrence points, clustering, and optional heatmap layer.", usedBy: 38, version: "2.1.0" },
  { name: "csv_loader", type: "loader", body: "Load tabular data from CSV files with type detection and field mapping.", usedBy: 67, version: "3.0.2" },
  { name: "static_website", type: "exporter", body: "Render a full static HTML site with maps, charts, and taxon pages.", usedBy: 52, version: "2.5.1" },
  { name: "field_statistics", type: "transformer", body: "Compute mean, median, min/max, and quartiles over numeric fields grouped by entity.", usedBy: 31, version: "1.2.0" },
  { name: "phenology_timeline", type: "widget", body: "Horizontal timeline of phenological observations (flowering, fruiting) across a year.", usedBy: 15, version: "1.0.3" },
  { name: "geopackage_loader", type: "loader", body: "Load spatial data from GeoPackage files (vectors + rasters) with CRS handling.", usedBy: 29, version: "1.5.0" },
  { name: "darwin_core_export", type: "exporter", body: "Export occurrences as Darwin Core Archive (DwC-A) for GBIF submission.", usedBy: 18, version: "1.1.0" },
  { name: "top_ranking", type: "transformer", body: "Rank the top N values of a field (e.g., most abundant species, most common families).", usedBy: 22, version: "1.3.1" },
  { name: "scatter_plot", type: "widget", body: "X/Y scatter plot with optional color grouping and regression line.", usedBy: 28, version: "1.4.2" },
  { name: "postgres_loader", type: "loader", body: "Stream data from a live PostgreSQL database via SQL queries.", usedBy: 9, version: "0.9.0" },
  { name: "api_json_export", type: "exporter", body: "Expose entities as a REST-like JSON API (static files).", usedBy: 14, version: "1.0.0" },
];

const filters = [
  { id: "all", label: "All", count: 90, active: true },
  { id: "transformer", label: "Transformers", count: 42 },
  { id: "widget", label: "Widgets", count: 28 },
  { id: "loader", label: "Loaders", count: 12 },
  { id: "exporter", label: "Exporters", count: 8 },
];
---

<BaseLayout
  title="Plugins — Niamoto"
  description="Niamoto is extended through four plugin types: Transformers, Widgets, Loaders, Exporters. Mix and match to shape your pipeline."
>
  <Header active="plugins" />

  <!-- Hero -->
  <section class="bg-canvas py-16">
    <div class="mx-auto max-w-[1200px] px-6 text-center">
      <h1 class="text-5xl font-bold tracking-[-0.02em] text-ink">
        Plugins for every ecological workflow
      </h1>
      <p class="mx-auto mt-3 max-w-[720px] text-lg text-stone">
        Niamoto is extended through four plugin types. Mix and match to shape
        your pipeline — from raw CSVs to published portals.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-2">
        <span class="rounded-[999px] bg-white px-4 py-1.5 text-sm text-ink shadow-[0_1px_2px_rgba(15,23,42,0.04)]">
          42 Transformers
        </span>
        <span class="rounded-[999px] bg-white px-4 py-1.5 text-sm text-ink shadow-[0_1px_2px_rgba(15,23,42,0.04)]">
          28 Widgets
        </span>
        <span class="rounded-[999px] bg-white px-4 py-1.5 text-sm text-ink shadow-[0_1px_2px_rgba(15,23,42,0.04)]">
          12 Loaders
        </span>
        <span class="rounded-[999px] bg-white px-4 py-1.5 text-sm text-ink shadow-[0_1px_2px_rgba(15,23,42,0.04)]">
          8 Exporters
        </span>
      </div>
    </div>
  </section>

  <!-- Filter bar -->
  <div class="sticky top-[73px] z-40 border-b border-border bg-white/95 backdrop-blur-md">
    <div
      class="mx-auto flex max-w-[1200px] flex-wrap items-center justify-between gap-4 px-6 py-4"
    >
      <nav class="flex flex-wrap gap-6 text-sm">
        {
          filters.map((f) => (
            <a
              href={`#${f.id}`}
              class:list={[
                "pb-1",
                f.active
                  ? "border-b-2 border-forest-green font-semibold text-ink"
                  : "text-stone hover:text-ink",
              ]}
            >
              {f.label} ({f.count})
            </a>
          ))
        }
      </nav>
      <div class="flex items-center gap-3 text-xs text-stone">
        <input
          type="search"
          placeholder="Search plugins..."
          class="rounded-[6px] border border-border bg-white px-3 py-1.5 font-mono text-xs text-ink placeholder:text-stone-light focus:border-forest-green focus:outline-none"
        />
        <span>Most used ▾</span>
      </div>
    </div>
  </div>

  <!-- Grid -->
  <section class="mx-auto max-w-[1200px] px-6 py-16">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        plugins.map((p) => {
          const style = typeStyle[p.type];
          return (
            <div class="flex flex-col rounded-[12px] bg-white p-6 shadow-[0_4px_12px_rgba(15,23,42,0.06)]">
              <span
                class="self-start rounded-[999px] px-2.5 py-0.5 font-mono text-[10px] font-bold uppercase tracking-wider"
                style={`background:${style.bg}; color:${style.color}`}
              >
                {style.label}
              </span>
              <h3 class="mt-3 font-mono text-lg font-bold text-ink">
                {p.name}
              </h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-ink/80">
                {p.body}
              </p>
              <div class="mt-4 flex items-center justify-between text-xs text-stone">
                <span>Used by {p.usedBy} projects</span>
                <span class="font-mono">v{p.version}</span>
              </div>
            </div>
          );
        })
      }
    </div>
  </section>

  <!-- Contribute -->
  <section class="bg-canvas py-24">
    <div class="mx-auto max-w-[800px] px-6 text-center">
      <h2 class="text-[32px] font-bold text-ink">Build your own</h2>
      <p class="mt-3 text-[15px] leading-relaxed text-stone">
        Plugins are plain Python with a YAML contract. Clone the template,
        implement your logic, register it with a decorator.
      </p>

      <pre class="mx-auto mt-8 max-w-[640px] overflow-auto rounded-[8px] bg-[#16161A] p-4 text-left font-mono text-[13px] leading-relaxed text-[#E5E7EB]"><code>@register("my_plugin", PluginType.TRANSFORMER)
class MyPlugin(Transformer):
    config_model = MyPluginConfig
    ...</code></pre>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <Button
          variant="outline"
          href="/documentation"
          size="md"
        >
          Read the Plugin API
        </Button>
        <a
          href="https://github.com/niamoto/niamoto-plugin-template"
          class="text-sm font-medium text-steel-blue hover:underline"
        >
          Plugin template repo →
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
