---
import AltLayout from "@/layouts/AltLayout.astro";
---

<AltLayout
  theme="atlas"
  locale="en"
  title="Niamoto — Landing alternatives"
  description="Four design directions for the Niamoto open-source ecological data platform site."
  slug=""
>
  <main class="mx-auto max-w-[1200px] px-6 py-32">
    <h1 class="display text-6xl">Smoke test: Atlas tokens</h1>
    <p class="mt-6 text-lg text-muted">
      If you can read this in Fraunces serif on a cream background, the foundation works.
    </p>
    <p class="mt-4 font-mono text-sm text-accent">
      pip install niamoto
    </p>
  </main>
</AltLayout>
